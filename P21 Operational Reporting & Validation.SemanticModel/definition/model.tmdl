model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Dimensions

	annotation PBI_QueryGroupOrder = 1

queryGroup Facts

	annotation PBI_QueryGroupOrder = 0

queryGroup Metadata

	annotation PBI_QueryGroupOrder = 4

/// Workspace names for dataflows are referenced
queryGroup Parameters

	annotation PBI_QueryGroupOrder = 2

queryGroup Functions

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Temp tables'

	annotation PBI_QueryGroupOrder = 6

annotation PBI_QueryOrder = ["Measure Table","RangeStart","RangeEnd","FilePath","Dataflow_LimitRecordCount","Dataflow_RecordCountLimit","Workspace","zLast Refresh Datetime","fx_ConditionallyLimitRows","fx_Loop","fx_TableProfile","fx_DistinctKeyChecker","fx_FilterDimByFact","fx_ConvertUTCtoET","zChange Log","zData Details","zDataset Information","zKnown Issues","zTime Series Definition","F_P21_Shipper_Component","F_P21_Shipper_Header","D_P21_Customer","D - Calendar Table","F_Inventory Location P21","F_P21_Orders_Header","F_P21_Orders_Line","F_P21_Shipper_Line"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBIDesktopVersion = 2.137.1102.0 (24.10)

annotation __TEdtr = 1

annotation PBI_ProTooling = ["DaxQueryView_Desktop"]

ref table 'Measure Table'
