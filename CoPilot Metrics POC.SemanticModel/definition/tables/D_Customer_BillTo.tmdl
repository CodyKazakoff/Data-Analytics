	partition D_Customer_BillTo = m
		mode: import
		queryGroup: Dimensions
		source = ```
				let
				    Source = Sql.Database(Lakehouse & ".datawarehouse.fabric.microsoft.com", "Enterprise_Analytics"),
				    dbo_D_Customer_BillTo = Value.NativeQuery(Source, "        
				    SELECT
				    BILLTO.*
				    FROM D_Customer_BillTo AS BILLTO
				        INNER JOIN (
				            SELECT DISTINCT BILL_TO_CUST_KEY FROM F_Shipper_Item
				        ) AS SHPR
				        ON BILLTO.BILLING_CUST_KEY = SHPR.BILL_TO_CUST_KEY
				        ", null, [EnableFolding = true]),
				#"Removed Unused Columns"= Table.SelectColumns(dbo_D_Customer_BillTo,{"BILLING_CUST_KEY"})
				in
				#"Removed Unused Columns"
				```

