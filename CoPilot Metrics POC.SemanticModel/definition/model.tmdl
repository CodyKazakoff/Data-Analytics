model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Dimensions

	annotation PBI_QueryGroupOrder = 1

queryGroup Facts

	annotation PBI_QueryGroupOrder = 0

queryGroup Metadata

	annotation PBI_QueryGroupOrder = 4

/// Workspace names for dataflows are referenced
queryGroup Parameters

	annotation PBI_QueryGroupOrder = 2

queryGroup Functions

	annotation PBI_QueryGroupOrder = 3

queryGroup 'Temp tables'

	annotation PBI_QueryGroupOrder = 6

annotation PBI_QueryOrder = ["Measure Table","RecordCountLimit","LimitRecordCount","Lakehouse","RangeStart","RangeEnd","z_Last_Refresh_Datetime","fx_ConditionallyLimitRows","fx_Loop","fx_TableProfile","fx_DistinctKeyChecker","D_Calendar_Filter","D_Calendar_Visual","D_Customer_BillTo","Example Date Range Power Query","F_Shipper_Item","F_ECOS_CoPilot_Agent_Actions_Header","D_Customer_ShipTo","D_Location","F_Order_Header","zOrder_Source_Slicer"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation __TEdtr = 1

annotation PBI_ProTooling = ["CalcGroup","TMDLView_Desktop"]

ref table 'Measure Table'
ref table z_Last_Refresh_Datetime
ref table 'Time Intelligence'
ref table D_Calendar_Filter
ref table D_Calendar_Visual
ref table F_Shipper_Item
ref table F_ECOS_CoPilot_Agent_Actions_Header
ref table D_Customer_BillTo
ref table D_Customer_ShipTo
ref table D_Location
ref table F_Order_Header
ref table zOrder_Source_Slicer

ref cultureInfo en-US

