expression fx_CreateCalendar = ```
		let
		    fx = (p_DateList as list, optional p_FirstFiscalPeriod as number) => let
		        /*  
		            Find the start date and end date of the fact table
		        */
		        StartDate                                               = Date.From(List.Min(p_DateList)),
		        EndDate                                                 = Date.From(List.Max(p_DateList)),
		        
		        // Load the distinct list of dates from the start date to end date and sort the table
		        ListDates                                               = List.Dates(StartDate, Number.From(EndDate - StartDate) + 1, #duration(1,0,0,0)),
		        #"Load Distinct All Dates"                              = Table.FromList(ListDates, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
		        #"Renamed Columns"                                      = Table.RenameColumns(#"Load Distinct All Dates",{{"Column1", "Date"}}),
		        #"Sorted Rows by Date Asc"                              = Table.Sort(#"Renamed Columns",{{"Date", Order.Ascending}}),
		        
		        // Add business friendly columns
		        #"Added Calendar Year"                                  = Table.AddColumn(#"Sorted Rows by Date Asc", "Year", each Date.Year([Date])),
		        #"Added Calendar Month of Year"                         = Table.AddColumn(#"Added Calendar Year", "Month of Year", each Text.Range(Date.MonthName([Date]), 0, 3)),
		        #"Added Calendar Month of Year Long"                    = Table.AddColumn(#"Added Calendar Month of Year", "Month of Year Long", each Date.MonthName([Date])),
		        #"Added Calendar Month Num"                              = Table.AddColumn(#"Added Calendar Month of Year Long", "Month Num", each Date.Month([Date])),
		        #"Added Calendar Quarter of Year"                       = Table.AddColumn(#"Added Calendar Month Num", "Quarter of Year", each "Q" & Number.ToText(Number.RoundUp([Month Num] / 3))),
		        #"Added Calendar Week of Year"                          = Table.AddColumn(#"Added Calendar Quarter of Year", "Week of Year", each Date.WeekOfYear([Date])),
		        #"Added Calendar Month"                                 = Table.AddColumn(#"Added Calendar Week of Year", "Month", each Text.From([Year]) &"-"& [Month of Year]),
		        #"Added Calendar Quarter"                               = Table.AddColumn(#"Added Calendar Month", "Quarter", each Text.From([Year]) &"-"& [Quarter of Year]),
		        #"Added Calendar Week"                                  = Table.AddColumn(#"Added Calendar Quarter", "Week", each Text.From([Year]) &"-W"& Text.From([Week of Year])),
		        #"Added Calendar Weekday"                               = Table.AddColumn(#"Added Calendar Week", "Weekday", each Text.Range(Date.DayOfWeekName([Date]), 0, 3)),
		        #"Added Calendar Weekday Num"                           = Table.AddColumn(#"Added Calendar Weekday", "Weekday Num", each Date.DayOfWeek([Date])),
		        #"Added Calendar Week Ending Date"                      = Table.AddColumn(#"Added Calendar Weekday Num", "Week Ending Date", each Date.EndOfWeek([Date])),
		        
		        // Add [Day of...] columns to enable time based variables 
		        #"Added Calendar Day of Year"                           = Table.AddColumn(#"Added Calendar Week Ending Date", "Day of Year", each Date.DayOfYear([Date])),
		        #"Added Calendar Day of Quarter"                        = Table.AddColumn(#"Added Calendar Day of Year", "Day of Quarter", each Number.From([Date]) - Number.From(Date.StartOfQuarter([Date])) + 1),
		        #"Added Calendar Day of Month"                          = Table.AddColumn(#"Added Calendar Day of Quarter", "Day of Month", each Date.Day([Date])),
		        
		        // Add  Index columns to enable time based variables and sorting of business friendly columns
		        // Year  Index is redundant with Year
		        //#"Added Calendar Year Index"                           = Table.AddColumn(#"Added Calendar Day of Month", "Year Index", each [Year]),
		        // Quarter & Month  Index is useful for sorting in UI
		        #"Added Calendar Quarter Index"                          = Table.AddColumn(#"Added Calendar Day of Month", "Quarter Index", each [Year] * 4 + Number.RoundUp([Month Num] / 3)),
		        #"Added Calendar Month Index"                            = Table.AddColumn(#"Added Calendar Quarter Index", "Month Index", each [Year] * 12 + Date.Month([Date])),
		        // Add Week Index column
		        #"Filtered Rows to Sundays only"                        = Table.SelectColumns(Table.SelectRows(#"Added Calendar Month Index", each ([Weekday] = "Sun")), "Week Ending Date"),
		        #"Created Week Index"                                    = Table.AddIndexColumn(#"Filtered Rows to Sundays only", "TempWeek Index", 2, 1),
		        #"Merged Queries Master Calendar to Week Index"          = Table.NestedJoin(#"Added Calendar Month Index",{"Week Ending Date"},#"Created Week Index",{"Week Ending Date"},"Added  Index WeekNum",JoinKind.LeftOuter),
		        #"Expanded to add Week Index"                            = Table.ExpandTableColumn(#"Merged Queries Master Calendar to Week Index", "Added  Index WeekNum", {"TempWeek Index"}, {"TempWeek Index"}),
		        #"Replaced nulls with 1s in Week Index"                  = Table.AddColumn(#"Expanded to add Week Index", "Week Index", each if [TempWeek Index] = null 
		            then 1
		            else [TempWeek Index]),
		        #"Removed TempWeek Index"                                = Table.RemoveColumns(#"Replaced nulls with 1s in Week Index",{"TempWeek Index"}),
		        
		        #"Added Calendar Date Index"                             = Table.AddColumn(#"Removed TempWeek Index", "Date Index", each Number.From([Date])),
		        
		        #"Added Calendar DateKey"                               = Table.AddColumn(#"Added Calendar Date Index", "Date Key", each Date.ToText([Date], "YYYYMMDD"), Int64.Type),
		
		        #"Added Fiscal Year" 
		            = Table.AddColumn(#"Added Calendar DateKey", "Fiscal Year"
		            , each 
		                if p_FirstFiscalPeriod <> null
		                    then if [Month Num] >= p_FirstFiscalPeriod
		                        then [Year]+1
		                        else [Year]
		                    else
		                        [Year]
		        ),
		
		        #"Added Fiscal Period Num" 
		            = Table.AddColumn(#"Added Fiscal Year", "Fiscal Period Num"
		            , each
		                if p_FirstFiscalPeriod <> null
		                    then if [Month Num] >= p_FirstFiscalPeriod
		                        then [Month Num]-(p_FirstFiscalPeriod-1)
		                        else [Month Num]+(12-p_FirstFiscalPeriod+1)
		                    else [Month Num]
		        ),
		
		        #"Added Fiscal Period"                                  = Table.AddColumn(#"Added Fiscal Period Num", "Fiscal Period", each Text.From([Fiscal Year]) &"-"& Text.PadStart(Text.From([Fiscal Period Num]), 2, "0")),
		
		        #"Added Fiscal Quarter of Year"                         = Table.AddColumn(#"Added Fiscal Period", "Fiscal Quarter of Year", each "Q" & Number.ToText(Number.RoundUp([Fiscal Period Num] / 3))),
		
		        #"Added Fiscal Quarter"                                 = Table.AddColumn(#"Added Fiscal Quarter of Year", "Fiscal Quarter", each Text.From([Fiscal Year]) &"-"& [Fiscal Quarter of Year]),
		        
		        // Change the data types to the final data types
		        Output 
		            = Table.TransformColumnTypes(#"Added Fiscal Quarter"
		            ,{
		                {"Date", type date}
		                , {"Date Key", Int64.Type}
		                , {"Year", Int64.Type}
		                , {"Month of Year", type text}
		                , {"Month Num", Int64.Type}
		                , {"Quarter of Year", type text}
		                , {"Week of Year", Int64.Type}
		                , {"Month", type text}
		                , {"Quarter", type text}
		                , {"Week", type text}
		                , {"Weekday", type text}
		                , {"Week Ending Date", type date}
		                , {"Day of Year", Int64.Type}
		                , {"Day of Quarter", Int64.Type}
		                , {"Day of Month", Int64.Type}
		                //, {"Year Index", Int64.Type}
		                , {"Quarter Index", Int64.Type}
		                , {"Month Index", Int64.Type}
		                , {"Week Index", Int64.Type}
		                , {"Date Index", Int64.Type}
		                , {"Weekday Num", Int64.Type}
		                , {"Month of Year Long", type text}
		                , {"Fiscal Year", Int64.Type}
		                , {"Fiscal Period Num", Int64.Type}
		                , {"Fiscal Period", type text}
		                , {"Fiscal Quarter of Year", type text}
		                , {"Fiscal Quarter", type text}
		            })
		    in
		        Output,
		        fx_Type = type function
		        (
		            p_DateList as list
		            , optional p_FirstFiscalPeriod as number
		        ) as table meta
		        [
		            Documentation.Name = "fx_CreateCalendar"
		            , Documentation.Description = "This function takes a list of dates and generates all possible dates between the min and max date provided. Optionally, provide a first fiscal period to generate Fiscal Year, Fiscal Period, and Fiscal Quarter."
		            , Documentation.Examples = 
		            {
		                [
		                    Description = "Example usage of fx_CreateCalendar without first fiscal period"
		                    , Code = "fx_CreateCalendar(Sales[Date])"
		                    , Result = "A table containing all dates between the min and max dates from the date list provided. The Fiscal columns will match the calendar equivalents (ex: Fiscal Year = Year)"
		                ],
		                [
		                    Description = "Example usage of fx_CreateCalendar with first fiscal period"
		                    , Code = "fx_CreateCalendar(Sales[Date], 10)"
		                    , Result = "A table containing all dates between the min and max dates from the date list provided. The Fiscal periods will be based off the first fiscal period provided.#(cr)Ex: If first fiscal period = 10, the first period in the fiscal calendar will be 10."
		                ]
		            }
		        ]
		in
		Value.ReplaceType(fx, fx_Type)
		```
	lineageTag: 8dd23062-7f2a-43b0-8e56-16972936956f
	queryGroup: Metadata\Functions

	annotation PBI_ResultType = Function

	annotation PBI_NavigationStepName = Navigation

expression fx_Loop = ```
		let
		    fx = (
		            p_startIteration as number
		            , p_endIteration as number
		            , p_increment as number
		            //Function to be called on each iteration. This function should be expecting a numeric iteration paramter
		            , p_function as function
		            , optional p_combineresultsets as logical
		            , optional p_result as table
		            , optional p_currentIteration as number) =>
		    let
		        currentIteration =              if p_currentIteration = null
		                                            then p_startIteration
		                                            else p_currentIteration,
		        //Run function that gets table for current iterations min/max dates
		        currentResultSet =              @p_function(currentIteration, p_result),
		        //Combine current table with prior iterations (if there are prior iterations)
		        fullResultTable =               if p_result = null or p_combineresultsets = false
		                                                then currentResultSet
		                                                else Table.Combine({p_result, currentResultSet}),
		        //Increment loop
		        nextIteration = currentIteration + p_increment,
		        //If there are still iterations to run, call this function again and pass the next iteration and the current table to append to
		        //Otherwise, return the current output.
		        Output = 
		        if nextIteration <= p_endIteration
		            then @fx_Loop(p_startIteration, p_endIteration, p_increment, p_function, p_combineresultsets, fullResultTable, nextIteration)
		            else fullResultTable
		    in
		    Output
		    , fx_Type = type function
		    (
		        p_startIteration as number
		        , p_endIteration as number
		        , p_increment as number
		        //Function to be called on each iteration. This function should be expecting a numeric iteration paramter
		        , p_function as function
		        , optional p_combineresultsets as logical
		        , optional p_result as table
		        , optional p_currentIteration as number
		    ) as any meta
		    [
		        Documentation.Name = "fx_Loop"
		        , Documentation.Description = "This function provides a facility to iterate over a list of values and exucute a user defined function in each iteration. When invoking this function, you should never need to define p_result or p_currentIteration, those are defined as part of the fx_Loop itself."
		        , Documentation.Examples = 
		        {
		            [
		                Description = "Iterate from 0 to 9 by 1 and add each number to a table. Return a table with values 0 to 9."
		                , Code = 
		"fx_Loop(
		    0
		    , 9
		    , 1
		    , (p_iteration as number, optional p_result as table) => let
		        //Logic that uses current iteration
		        loopOutput          = #table({""Column""}, {{p_iteration}})
		    in
		        //Output that will be used as result.
		        loopOutput
		)"
		                , Result = 
		"{
		    [Column = 0]
		    , [Column = 1]
		    , [Column = 2]
		    , [Column = 3]
		    , [Column = 4]
		    , [Column = 5]
		    , [Column = 6]
		    , [Column = 7]
		    , [Column = 8]
		    , [Column = 9]
		}"
		            ]
		            , [
		                Description = "Iterate from 0 to 9 by 1 and add each number to a table. Return with only the last result."
		                , Code = 
		"fx_Loop(
		    0
		    , 9
		    , 1
		    , (p_iteration as number, optional p_result as table) => let
		        //Logic that uses current iteration
		        loopOutput          = #table({""Column""}, {{p_iteration}})
		    in
		        //Output that will be used as result.
		        loopOutput
		    , false
		)"
		                , Result = 
		"{
		    [Column = 0]
		    , [Column = 1]
		    , [Column = 2]
		    , [Column = 3]
		    , [Column = 4]
		    , [Column = 5]
		    , [Column = 6]
		    , [Column = 7]
		    , [Column = 8]
		    , [Column = 9]
		}"
		            ]
		        }
		    ]
		    
		in
		Value.ReplaceType(fx, fx_Type)
		```
	lineageTag: 5f47af5b-a622-4ee0-974e-670281b92efd
	queryGroup: Metadata\Functions

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression fx_TableProfile = ```
		let
		    //This is a comment
		    fx = (p_SourceTable as table, optional p_ColumnName as text, optional p_TableName as text) => let
		        filteredSouceTable              = if p_ColumnName <> null
		                                            then Table.SelectColumns(p_SourceTable,{p_ColumnName})
		                                            else p_SourceTable,
		
		        //Get the base profile table for the table we want to profile
		        tempProfile                     = Table.Profile(
		                                            filteredSouceTable,
		                                            {
		                                                {"Median", each Type.Is(_, type number), List.Median}
		                                                , {"Mode", each Type.Is(_, type number), List.Mode}
		                                            }
		                                        ),
		        tempProfileRemovedColumns       = Table.RemoveColumns(tempProfile,
		                                            {
		                                                "DistinctCount"
		                                            }),
		        tempProfileRenamedColumns       = Table.RenameColumns(tempProfileRemovedColumns,
		                                            {
		                                                {"Count", "Row Count"}
		                                            }),
		        //Add an index column that we can use to loop over rows.
		        Profile                         = Table.AddIndexColumn(tempProfileRenamedColumns, "Column Index", 0, 1, Int64.Type),
		
		        //Add % of values in column that are null & flag columns that are 100% null
		        #"% Null"                       = Table.AddColumn(Profile, "% Null", each [NullCount] / [Row Count], Percentage.Type),
		        #"Flag.Contains Nulls"              = Table.AddColumn(#"% Null", "Flag.Contains Nulls", each if [NullCount] > 0 then true else false, type logical),
		   
		        //Start loop function
		        LoopOutput = fx_Loop(
		            //Loop params
		            //Loop Start
		            0
		            //Loop End
		            , (Table.RowCount(Profile) - 1)
		            //Loop Increment
		            , 1
		            //Create function that will be looped over
		            , (p_iteration as number, optional p_result as table) => let
		
		                //Get the row that we're interested in, based on the iteration
		                fieldRow                = Table.SelectRows(#"Flag.Contains Nulls", each [Column Index] = p_iteration),
		
		                //Get column name for use in later steps
		                columnName              = fieldRow{0}[Column],
		                
		                //Get a list of all the values for a field so we can interrogate it.
		                fieldValues         = Table.Column(filteredSouceTable, columnName),
		    
		                //Add % of values in column that are Distinct
		                //Recalculating Distinct count because the default method that comes out of Table.Profile throws an error if there are nulls in the column
		                DistinctValues          = List.Count(List.Distinct(fieldValues)),
		                AddDistinctValues       = Table.AddColumn(fieldRow, "Distinct Values", each DistinctValues, type number),
		                #"% Distinct"           = Table.AddColumn(AddDistinctValues, "% Distinct", each [Distinct Values] / [Row Count], Percentage.Type),
		                #"Flag.100% Distinct"   = Table.AddColumn(#"% Distinct", "Flag.100% Distinct", each if [#"% Distinct"] = 1 then true else false, type logical),
		
		                BlankCount              = List.Count(List.Select(fieldValues, each Text.Trim(Text.From(_)) = "")),
		                AddBlankCount           = Table.AddColumn(#"Flag.100% Distinct", "BlankCount", each BlankCount, type number),
		                
		                //Add % of values in column that are Blank
		                #"% Blank"              = Table.AddColumn(AddBlankCount, "% Blank", each [BlankCount] / [Row Count], Percentage.Type),
		                #"Flag.Contains Blanks" = Table.AddColumn(#"% Blank", "Flag.Contains Blanks", each if [BlankCount] > 0 then true else false, type logical),
		
		                BlankError              = if BlankCount > 0 then Text.Combine({columnName, " Contains Blanks"}) else null,
		                NullError               = if fieldRow{0}[NullCount] > 0 then Text.Combine({columnName, " Contains Nulls"}) else null,
		
		                Errors                  = if
		                                            BlankError <> null
		                                            or NullError <> null
		                                            //or TestError <> null
		                                            then 
		                                                error Error.Record(Text.Combine({"Errors were found in ", columnName})
		                                                , "Check this column for errors"
		                                                , Text.Combine(
		                                                    {
		                                                        "#(tab)"
		                                                        , if BlankError <> null then Text.Combine({BlankError, "#(cr,tab)"}) else null
		                                                        , if NullError <> null then Text.Combine({NullError, "#(cr,tab)"}) else null
		                                                    })
		                                                )
		                                            else null,
		
		                AddErrorColumn          = Table.AddColumn(#"Flag.Contains Blanks", "Errors", each Errors, type logical),
		
		                //Add table name. This is useful when we're profiling the whole dataset, rather than just an individual table.
		                TableName               = if p_TableName = null
		                                            then "Table"
		                                            else p_TableName,
		                
		                //Add table name column, and send output to next iteration
		                loopOutput              = Table.AddColumn(AddErrorColumn, "Table Name", each TableName, type text)
		            in
		                //Output that will be used as result.
		                loopOutput),
		        LoopOutputRemoveColumns         = Table.RemoveColumns(LoopOutput,
		                                            {
		                                                "Column Index"
		                                            }),
		        
		        #"Reorder Columns"              = Table.ReorderColumns(LoopOutputRemoveColumns,
		            {
		                "Column"
		                , "Errors"
		                , "Flag.100% Distinct"
		                , "Flag.Contains Nulls"
		                , "Flag.Contains Blanks"
		                , "Distinct Values"
		                , "Row Count"
		                , "% Distinct"
		                , "NullCount"
		                , "% Null"
		                , "BlankCount"
		                , "% Blank"
		                , "Min"
		                , "Max"
		                , "Average"
		                , "Median"
		                , "Mode"
		                , "StandardDeviation"
		            }),
		
		        Output                          = #"Reorder Columns"
		    in
		        Output
		        , fx_Type = type function
		        (
		            p_SourceTable as table
		            , optional p_ColumnName as text
		            , optional p_TableName as text
		        ) as table meta
		        [
		            Documentation.Name          = "fx_TableProfile"
		            , Documentation.Description = "This function takes a tabe, runs the Table.Profile function against it, and adds some additional profiling information.<br>Optionally add a column name p_ColumnName to only run profiling against that column.<br>p_TableName is not required and is only included to support fx_DatasetProfile. <br><br> This function relies on the function fx_Loop existing in the dataset."
		            , Documentation.Examples    = 
		            {
		                [
		                    Description         = "Example usage of fx_TableProfile against an entire table."
		                    , Code              = "fx_TableProfile(Sales)"
		                    , Result            = "A table containing the result of Table.Profile(Sales), plus % Null, % Distinct, % Blank, and an errors column calling out the errors found for each column."
		                ],
		                [
		                    Description         = "Example usage of fx_TableProfile against the Order Number column from the Sales table."
		                    , Code              = "fx_TableProfile(Sales, ""Order Number"")"
		                    , Result            = "A table containing the result of Table.Profile(Sales) for the Order Number column, plus % Null, % Distinct, % Blank, and an errors column calling out the errors found for the Order Number column."
		                ]
		            }
		        ]
		in
		Value.ReplaceType(fx, fx_Type)
		```
	lineageTag: 58ffd5f2-e1c8-4966-8502-e35ea5383abb
	queryGroup: Metadata\Functions

	annotation PBI_NavigationStepName = Navigation

