, {"PROJECTED AR ADMIN FEE", "    MI_LOC,"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "    SUM(OUTSTGAMT) as OUTSTGAMT,"}, {"PROJECTED AR ADMIN FEE", "    SUM(UNCONV_OUTSTGAMNT) as UNCONV_OUTSTGAMNT,"}, {"PROJECTED AR ADMIN FEE", "    SUM(PAST_DUE_AMT) as PAST_DUE_AMT,"}, {"PROJECTED AR ADMIN FEE", "    SUM(UNCONV_PAST_DUE_AMT) as UNCONV_PAST_DUE_AMT"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "RESIDENT PROD"}, {"PROJECTED AR ADMIN FEE", "WHERE 1=1"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "    "}, {"PROJECTED AR ADMIN FEE", "GROUP BY MI_LOC"}, {"PROJECTED AR ADMIN FEE", ";"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "LEFT JOIN(AR_FEE)"}, {"PROJECTED AR ADMIN FEE", "LOAD"}, {"PROJECTED AR ADMIN FEE", "    "}, {"PROJECTED AR ADMIN FEE", "    MI_LOC,"}, {"PROJECTED AR ADMIN FEE", "    MI_GROUP_LOC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_LOC,"}, {"PROJECTED AR ADMIN FEE", "    OU,"}, {"PROJECTED AR ADMIN FEE", "    COUNTRY,"}, {"PROJECTED AR ADMIN FEE", "    PS_BU as BU,"}, {"PROJECTED AR ADMIN FEE", "    PS_GROUP_DESC as MI_GROUP_DESC,"}, {"PROJECTED AR ADMIN FEE", "    PS_DIVISION_DESC as MI_DIVISION_DESC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_LOC as DIV_ACCESS,"}, {"PROJECTED AR ADMIN FEE", "    MI_GROUP_LOC as GROUP_ACCESS"}, {"PROJECTED AR ADMIN FEE", "FROM [lib://QVD_FIN (motionhq_td020325)/Other/PS_ROLLUP/OUTPUT/OU_TREE_ROLLUP.qvd]"}, {"PROJECTED AR ADMIN FEE", "(qvd);"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "LIB CONNECT TO 'Floyd _ Blu (motionhq_cd010325)';"}, {"PROJECTED AR ADMIN FEE", "LEFT JOIN(AR_FEE)"}, {"PROJECTED AR ADMIN FEE", "LOAD ""MI_LOC"","}, {"PROJECTED AR ADMIN FEE", "    ""OPEN_CLOSED"";"}, {"PROJECTED AR ADMIN FEE", "SQL SELECT ""MI_LOC"","}, {"PROJECTED AR ADMIN FEE", "    ""OPEN_CLOSED"""}, {"PROJECTED AR ADMIN FEE", "FROM BROP.""LOCATION_PROFILE"";"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "CONCATENATE(PROD)  "}, {"PROJECTED AR ADMIN FEE", "LOAD"}, {"PROJECTED AR ADMIN FEE", "	'Y' & UPPER(TRIM(MI_GROUP_DESC)) & '|' & UPPER(TRIM(MI_DIVISION_DESC)) as AR_OPEN_AUTH_KEY,"}, {"PROJECTED AR ADMIN FEE", "    'AR Admin Fee' as Src,"}, {"PROJECTED AR ADMIN FEE", "    MI_LOC,"}, {"PROJECTED AR ADMIN FEE", "	MI_GROUP_LOC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_LOC,"}, {"PROJECTED AR ADMIN FEE", "    OU,"}, {"PROJECTED AR ADMIN FEE", "    BU,"}, {"PROJECTED AR ADMIN FEE", "    COUNTRY,"}, {"PROJECTED AR ADMIN FEE", "    MI_GROUP_DESC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_DESC,"}, {"PROJECTED AR ADMIN FEE", "    DIV_ACCESS,"}, {"PROJECTED AR ADMIN FEE", "    GROUP_ACCESS,"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "	SUM(IF(""OPEN_CLOSED""='C',0,FINAL_AR_FEE)) as FINAL_AR_FEE,"}, {"PROJECTED AR ADMIN FEE", "    SUM(IF(""OPEN_CLOSED""='C',0,UNCONV_FINAL_AR_FEE)) as UNCONV_FINAL_AR_FEE"}, {"PROJECTED AR ADMIN FEE", "    "}, {"PROJECTED AR ADMIN FEE", "RESIDENT AR_FEE"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "GROUP BY"}, {"PROJECTED AR ADMIN FEE", "	'Y' & UPPER(TRIM(MI_GROUP_DESC)) & '|' & UPPER(TRIM(MI_DIVISION_DESC)),"}, {"PROJECTED AR ADMIN FEE", "    'AR Admin Fee',"}, {"PROJECTED AR ADMIN FEE", "    MI_LOC,"}, {"PROJECTED AR ADMIN FEE", "	MI_GROUP_LOC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_LOC,"}, {"PROJECTED AR ADMIN FEE", "    OU,"}, {"PROJECTED AR ADMIN FEE", "    BU,"}, {"PROJECTED AR ADMIN FEE", "    COUNTRY,"}, {"PROJECTED AR ADMIN FEE", "    MI_GROUP_DESC,"}, {"PROJECTED AR ADMIN FEE", "    MI_DIVISION_DESC,"}, {"PROJECTED AR ADMIN FEE", "    DIV_ACCESS,"}, {"PROJECTED AR ADMIN FEE", "    GROUP_ACCESS"}, {"PROJECTED AR ADMIN FEE", ";"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "//STORE PROD INTO [lib://QVD_FIN (motionhq_td020325)/Other/Excel/AA.csv](txt);"}, {"PROJECTED AR ADMIN FEE", ""}, {"PROJECTED AR ADMIN FEE", "DROP TABLE AR_FEE;"}
				}
				, {"Script Page", "Script Line"}
			),
			#"Changed Type" = Table.TransformColumnTypes(Source,{{"Script Page", type text}, {"Script Line", type text}})
		in
			 #"Changed Type"
	lineageTag: e51dbb05-dbe3-423e-8d86-66930f494f91
	queryGroup: 'Conversion Information'

	annotation PBI_ResultType = Table

/// Table of scripts that were derived from the source document this was created from.
expression 'Vortex - Data Source Script Groups' =
		let
			Source = Table.FromRows(
				{
					{"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "SECURITY_FINAL", "FIELD_SECURITY_ACCESS", "", "From", "Load", "LOAD
		PRE_ACCESS,
		""USERID"",
		AR_OPEN_AUTH_KEY
		FROM [lib://QVD_FIN (motionhq_td020325)/Security/SYS_GEN/FIELD_SECURITY_ACCESS.qvd]
		(qvd)", "LOAD
		PRE_ACCESS,
		""USERID"",
		AR_OPEN_AUTH_KEY
		FROM [lib://QVD_FIN (motionhq_td020325)/Security/SYS_GEN/FIELD_SECURITY_ACCESS.qvd]
		(qvd)"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "AUTHORIZATION", "SECURITY_FINAL", "", "Resident", "Load", "LOAD
		PRE_ACCESS AS ACCESS,
		USERID,
		AR_OPEN_AUTH_KEY
		RESIDENT SECURITY_FINAL", "LOAD
		PRE_ACCESS AS ACCESS,
		USERID,
		AR_OPEN_AUTH_KEY
		RESIDENT SECURITY_FINAL"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "", "", "Floyd _ Blu (motionhq_cd010325)", "None", "EstablishConnection", "LIB CONNECT TO 'Floyd _ Blu (motionhq_cd010325)'
		", "LIB CONNECT TO 'Floyd _ Blu (motionhq_cd010325)'
		"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "DATA", "Unknown", "Floyd _ Blu (motionhq_cd010325)", "From", "Load", "LOAD
		IF(OUTSTANDING = 0, OUTSTGAMT) as CURRENT_AMT,
		IF(AR_BRACKET_ORDER = 1, OUTSTGAMT) as AMT_1_30,
		IF(AR_BRACKET_ORDER = 2, OUTSTGAMT) as AMT_31_60,
		IF(AR_BRACKET_ORDER = 3, OUTSTGAMT) as AMT_61_90,
		IF(AR_BRACKET_ORDER = 4, OUTSTGAMT) as AMT_90,
		IF(OUTSTANDING = 1, OUTSTGAMT) as PAST_DUE_AMT,
		IF(OUTSTGAMT < 0, 1,0) as CREDIT_BAL,
		*
		LOAD
		*,
		
		
		IF(AR_BRACKET = '1-30', 1,
		IF(AR_BRACKET = '31-60', 2,
		IF(AR_BRACKET = '61-90', 3,
		IF(AR_BRACKET = '90+', 4)))) as AR_BRACKET_ORDER
		LOAD
		*,
		MI_LOC & AR_CUSTOMER_NO & '00' as CUSTOMER_NO_PK,
		
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING <= 30, '1-30',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 30 and DAYS_OUTSTANDING <= 60, '31-60',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60 and DAYS_OUTSTANDING <= 90, '61-90',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 90, '90+'
		)))) as AR_BRACKET,
		
		IF(OUTSTANDING = 0, 'Current',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING <= 30, '1-30',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 30 and DAYS_OUTSTANDING <= 60, '31-60',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60 and DAYS_OUTSTANDING <= 90, '61-90',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 90, '90+'
		))))) as AR_BRACKET_FULL
		LOAD
		*,
		IF(OUTSTANDING = 1, Date(Floor(TODAY_DATE)) - Date(Floor(DUEDATE)),0) as DAYS_OUTSTANDING,
		IF(OUTSTGAMT < 0 ,'Y','N') as OUTSTGAMT_CREDIT_BALANCE,
		IF(OUTSTANDING = 1, 1,0) as NO_OUTSTANDING,
		IF(Date(Floor(DUEDATE)) - Date(Floor(TODAY_DATE)) <=30 AND OUTSTANDING = 0, OUTSTGAMT) as DUE_IN_30,
		IF(Date(Floor(DUEDATE)) - Date(Floor(TODAY_DATE)) <=30 AND OUTSTANDING = 0, 1) as DUE_IN_30_COUNT
		LOAD
		*,
		IF(MI_LOC <> 'AL00', 'N','Y') as NOT_CORP,
		IF(TODAY_DATE > DUEDATE, 1,0) as OUTSTANDING,
		Num(Month(INVDATE)) & YEAR(INVDATE) as DATE_KEY
		LOAD
		""SUB"",
		CUSTACCTNO & ITEMID as BAL_PK,
		BU,
		text(ITEMID) as ITEMID,
		text(RIGHT(TEXT(ITEMID),6)) as SHIPPER_CTL_NO,
		INVDATE,
		MI_CORP_LOC,
		DUEDATE,
		CUSTNAME,
		LEFT(CUSTACCTNO,4) as MI_LOC,
		CUSTACCTNO,
		text(RIGHT(text(CUSTACCTNO), 6)) as AR_CUSTOMER_NO,
		text(PO) as PO,
		ORIGAMT,
		ORIGAMT - OUTSTGAMT as PAID_AMOUNT,
		OUTSTGAMT,
		DISCAMT,
		DISCDATE,
		1 as NO_INVOICES,
		Date(Today(), 'YYYY-MM-DD') as TODAY_DATE,
		
		IF(ISNULL(ORDER_CTL_NO), ORDER_CTL_NO2, ORDER_CTL_NO) as ORDER_CTL_NO,
		IF(ISNULL(SHIP_TO_CUST_NO), SHIP_TO_CUST_NO2, SHIP_TO_CUST_NO) as SHIP_TO_CUST_NO,
		
		IF(ISNULL(TOTAL_SHIP_AMT), TOTAL_SHIP_AMT2, TOTAL_SHIP_AMT) as TOTAL_SHIP_AMT,
		IF(ISNULL(TOT_NET_AMOUNT), TOT_NET_AMOUNT2, TOT_NET_AMOUNT) as TOT_NET_AMOUNT,
		IF(ISNULL(TOT_NET_COST), TOT_NET_COST2, TOT_NET_COST) as TOT_NET_COST,
		IF(ISNULL(TOTAL_FRT), TOTAL_FRT2, TOTAL_FRT) as TOTAL_FRT,
		IF(ISNULL(SALES_TAX_TOTAL), SALES_TAX_TOTAL2, SALES_TAX_TOTAL) as SALES_TAX_TOTAL,
		IF(ISNULL(OTHER), OTHER2, OTHER) as OTHER,
		IF(ISNULL(DISCOUNT_AMT), DISCOUNT_AMT2, DISCOUNT_AMT) as DISCOUNT_AMT,
		LAST_ORDER
		SELECT
		AC.""SUB"",
		AC.""BU"",
		AC.""ITEMID"",
		AC.""INVDATE"",
		AC.""DUEDATE"",
		AC.""CUSTNAME"",
		AC.""CUSTACCTNO"",
		AC.""PO"",
		AC.""ORIGAMT"",
		AC.""OUTSTGAMT"",
		AC.""DISCAMT"",
		AC.""DISCDATE"",
		SB.MI_CORP_LOC,
		
		SH.SHIP_TO_CUST_NO,
		SH.TOT_NET_AMOUNT,
		SH.TOT_NET_COST,
		SH.TOTAL_FRT,
		SH.SALES_TAX_TOTAL,
		SH.OTHER,
		SH.ORDER_CTL_NO,
		SH.TOTAL_SHIP_AMT,
		SH.DISCOUNT_AMT,
		
		SH2.TOT_NET_AMOUNT2,
		SH2.TOT_NET_COST2,
		SH2.TOTAL_FRT2,
		SH2.SALES_TAX_TOTAL2,
		SH2.OTHER2,
		SH2.TOTAL_SHIP_AMT2,
		SH2.DISCOUNT_AMT2,
		SH2.ORDER_CTL_NO2,
		SH2.SHIP_TO_CUST_NO2,
		
		MC.LAST_ORDER
		
		FROM (SELECT
		AC.""SUB"",
		AC.""BU"",
		AC.""ITEMID"",
		AC.""INVDATE"",
		AC.""DUEDATE"",
		AC.""CUSTNAME"",
		AC.""CUSTACCTNO"",
		AC.""PO"",
		SUM(AC.""ORIGAMT"") AS ORIGAMT,
		SUM(AC.""OUTSTGAMT"") AS OUTSTGAMT,
		SUM(AC.""DISCAMT"") AS DISCAMT,
		AC.""DISCDATE""
		
		FROM ""EDW_FIN"".""AR_OPEN_INVOICES_CURRENT"" AS AC
		GROUP BY SUB, BU, ITEMID, INVDATE, DUEDATE, CUSTNAME, CUSTACCTNO, PO, DISCDATE
		
		) AS AC
		
		LEFT JOIN WHSE.SALES_BRANCH_MODEL AS SB
		ON SUBSTR(AC.CUSTACCTNO,1,4) = SB.MI_LOC
		
		LEFT JOIN
		
		(SELECT
		CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,3)) AS ITEM_ID,
		MAX(CUSTOMER_NO) as SHIP_TO_CUST_NO,
		MAX(ORDER_CTL_NO) AS ORDER_CTL_NO,
		
		SUM(TOTAL_SHIP_AMT) AS TOTAL_SHIP_AMT,
		SUM(DISCOUNT_AMT) as DISCOUNT_AMT,
		SUM(TOT_NET_AMOUNT) AS TOT_NET_AMOUNT,
		SUM(TOT_NET_COST) AS TOT_NET_COST,
		SUM(TOTAL_FRT) AS TOTAL_FRT,
		SUM(SALES_TAX_TOTAL) AS SALES_TAX_TOTAL,
		SUM(OTHER_CHARGES) + SUM(RESTOCK_CHARGE) + SUM(TOTAL_VAS) AS OTHER
		
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,3))
		) AS SH
		
		ON AC.ITEMID = SH.ITEM_ID
		
		LEFT JOIN
		
		(SELECT
		CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,5)) AS ITEM_ID,
		MAX(CUSTOMER_NO) as SHIP_TO_CUST_NO2,
		MAX(ORDER_CTL_NO) AS ORDER_CTL_NO2,
		
		SUM(TOTAL_SHIP_AMT) AS TOTAL_SHIP_AMT2,
		SUM(DISCOUNT_AMT) as DISCOUNT_AMT2,
		SUM(TOT_NET_AMOUNT) AS TOT_NET_AMOUNT2,
		SUM(TOT_NET_COST) AS TOT_NET_COST2,
		SUM(TOTAL_FRT) AS TOTAL_FRT2,
		SUM(SALES_TAX_TOTAL) AS SALES_TAX_TOTAL2,
		SUM(OTHER_CHARGES) + SUM(RESTOCK_CHARGE) + SUM(TOTAL_VAS) AS OTHER2
		
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,5))
		) AS SH2
		
		ON AC.ITEMID = SH2.ITEM_ID
		
		
		LEFT JOIN
		(SELECT
		CONCAT(MI_LOC, SUBSTR(BILL_TO_CUST_NO,1,6)) AS MAX_CUSTPK,
		MAX(SALES_POSTED_DATE) AS LAST_ORDER
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(BILL_TO_CUST_NO,1,6))
		) AS MC
		
		ON AC.CUSTACCTNO = MC.MAX_CUSTPK
		WITH UR", "LOAD
		IF(OUTSTANDING = 0, OUTSTGAMT) as CURRENT_AMT,
		IF(AR_BRACKET_ORDER = 1, OUTSTGAMT) as AMT_1_30,
		IF(AR_BRACKET_ORDER = 2, OUTSTGAMT) as AMT_31_60,
		IF(AR_BRACKET_ORDER = 3, OUTSTGAMT) as AMT_61_90,
		IF(AR_BRACKET_ORDER = 4, OUTSTGAMT) as AMT_90,
		IF(OUTSTANDING = 1, OUTSTGAMT) as PAST_DUE_AMT,
		IF(OUTSTGAMT < 0, 1,0) as CREDIT_BAL,
		*
		LOAD
		*,
		
		
		IF(AR_BRACKET = '1-30', 1,
		IF(AR_BRACKET = '31-60', 2,
		IF(AR_BRACKET = '61-90', 3,
		IF(AR_BRACKET = '90+', 4)))) as AR_BRACKET_ORDER
		LOAD
		*,
		MI_LOC & AR_CUSTOMER_NO & '00' as CUSTOMER_NO_PK,
		
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING <= 30, '1-30',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 30 and DAYS_OUTSTANDING <= 60, '31-60',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60 and DAYS_OUTSTANDING <= 90, '61-90',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 90, '90+'
		)))) as AR_BRACKET,
		
		IF(OUTSTANDING = 0, 'Current',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING <= 30, '1-30',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 30 and DAYS_OUTSTANDING <= 60, '31-60',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60 and DAYS_OUTSTANDING <= 90, '61-90',
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 90, '90+'
		))))) as AR_BRACKET_FULL
		LOAD
		*,
		IF(OUTSTANDING = 1, Date(Floor(TODAY_DATE)) - Date(Floor(DUEDATE)),0) as DAYS_OUTSTANDING,
		IF(OUTSTGAMT < 0 ,'Y','N') as OUTSTGAMT_CREDIT_BALANCE,
		IF(OUTSTANDING = 1, 1,0) as NO_OUTSTANDING,
		IF(Date(Floor(DUEDATE)) - Date(Floor(TODAY_DATE)) <=30 AND OUTSTANDING = 0, OUTSTGAMT) as DUE_IN_30,
		IF(Date(Floor(DUEDATE)) - Date(Floor(TODAY_DATE)) <=30 AND OUTSTANDING = 0, 1) as DUE_IN_30_COUNT
		LOAD
		*,
		IF(MI_LOC <> 'AL00', 'N','Y') as NOT_CORP,
		IF(TODAY_DATE > DUEDATE, 1,0) as OUTSTANDING,
		Num(Month(INVDATE)) & YEAR(INVDATE) as DATE_KEY
		LOAD
		""SUB"",
		CUSTACCTNO & ITEMID as BAL_PK,
		BU,
		text(ITEMID) as ITEMID,
		text(RIGHT(TEXT(ITEMID),6)) as SHIPPER_CTL_NO,
		INVDATE,
		MI_CORP_LOC,
		DUEDATE,
		CUSTNAME,
		LEFT(CUSTACCTNO,4) as MI_LOC,
		CUSTACCTNO,
		text(RIGHT(text(CUSTACCTNO), 6)) as AR_CUSTOMER_NO,
		text(PO) as PO,
		ORIGAMT,
		ORIGAMT - OUTSTGAMT as PAID_AMOUNT,
		OUTSTGAMT,
		DISCAMT,
		DISCDATE,
		1 as NO_INVOICES,
		Date(Today(), 'YYYY-MM-DD') as TODAY_DATE,
		
		IF(ISNULL(ORDER_CTL_NO), ORDER_CTL_NO2, ORDER_CTL_NO) as ORDER_CTL_NO,
		IF(ISNULL(SHIP_TO_CUST_NO), SHIP_TO_CUST_NO2, SHIP_TO_CUST_NO) as SHIP_TO_CUST_NO,
		
		IF(ISNULL(TOTAL_SHIP_AMT), TOTAL_SHIP_AMT2, TOTAL_SHIP_AMT) as TOTAL_SHIP_AMT,
		IF(ISNULL(TOT_NET_AMOUNT), TOT_NET_AMOUNT2, TOT_NET_AMOUNT) as TOT_NET_AMOUNT,
		IF(ISNULL(TOT_NET_COST), TOT_NET_COST2, TOT_NET_COST) as TOT_NET_COST,
		IF(ISNULL(TOTAL_FRT), TOTAL_FRT2, TOTAL_FRT) as TOTAL_FRT,
		IF(ISNULL(SALES_TAX_TOTAL), SALES_TAX_TOTAL2, SALES_TAX_TOTAL) as SALES_TAX_TOTAL,
		IF(ISNULL(OTHER), OTHER2, OTHER) as OTHER,
		IF(ISNULL(DISCOUNT_AMT), DISCOUNT_AMT2, DISCOUNT_AMT) as DISCOUNT_AMT,
		LAST_ORDER
		SELECT
		AC.""SUB"",
		AC.""BU"",
		AC.""ITEMID"",
		AC.""INVDATE"",
		AC.""DUEDATE"",
		AC.""CUSTNAME"",
		AC.""CUSTACCTNO"",
		AC.""PO"",
		AC.""ORIGAMT"",
		AC.""OUTSTGAMT"",
		AC.""DISCAMT"",
		AC.""DISCDATE"",
		SB.MI_CORP_LOC,
		
		SH.SHIP_TO_CUST_NO,
		SH.TOT_NET_AMOUNT,
		SH.TOT_NET_COST,
		SH.TOTAL_FRT,
		SH.SALES_TAX_TOTAL,
		SH.OTHER,
		SH.ORDER_CTL_NO,
		SH.TOTAL_SHIP_AMT,
		SH.DISCOUNT_AMT,
		
		SH2.TOT_NET_AMOUNT2,
		SH2.TOT_NET_COST2,
		SH2.TOTAL_FRT2,
		SH2.SALES_TAX_TOTAL2,
		SH2.OTHER2,
		SH2.TOTAL_SHIP_AMT2,
		SH2.DISCOUNT_AMT2,
		SH2.ORDER_CTL_NO2,
		SH2.SHIP_TO_CUST_NO2,
		
		MC.LAST_ORDER
		
		FROM (SELECT
		AC.""SUB"",
		AC.""BU"",
		AC.""ITEMID"",
		AC.""INVDATE"",
		AC.""DUEDATE"",
		AC.""CUSTNAME"",
		AC.""CUSTACCTNO"",
		AC.""PO"",
		SUM(AC.""ORIGAMT"") AS ORIGAMT,
		SUM(AC.""OUTSTGAMT"") AS OUTSTGAMT,
		SUM(AC.""DISCAMT"") AS DISCAMT,
		AC.""DISCDATE""
		
		FROM ""EDW_FIN"".""AR_OPEN_INVOICES_CURRENT"" AS AC
		GROUP BY SUB, BU, ITEMID, INVDATE, DUEDATE, CUSTNAME, CUSTACCTNO, PO, DISCDATE
		
		) AS AC
		
		LEFT JOIN WHSE.SALES_BRANCH_MODEL AS SB
		ON SUBSTR(AC.CUSTACCTNO,1,4) = SB.MI_LOC
		
		LEFT JOIN
		
		(SELECT
		CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,3)) AS ITEM_ID,
		MAX(CUSTOMER_NO) as SHIP_TO_CUST_NO,
		MAX(ORDER_CTL_NO) AS ORDER_CTL_NO,
		
		SUM(TOTAL_SHIP_AMT) AS TOTAL_SHIP_AMT,
		SUM(DISCOUNT_AMT) as DISCOUNT_AMT,
		SUM(TOT_NET_AMOUNT) AS TOT_NET_AMOUNT,
		SUM(TOT_NET_COST) AS TOT_NET_COST,
		SUM(TOTAL_FRT) AS TOTAL_FRT,
		SUM(SALES_TAX_TOTAL) AS SALES_TAX_TOTAL,
		SUM(OTHER_CHARGES) + SUM(RESTOCK_CHARGE) + SUM(TOTAL_VAS) AS OTHER
		
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,3))
		) AS SH
		
		ON AC.ITEMID = SH.ITEM_ID
		
		LEFT JOIN
		
		(SELECT
		CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,5)) AS ITEM_ID,
		MAX(CUSTOMER_NO) as SHIP_TO_CUST_NO2,
		MAX(ORDER_CTL_NO) AS ORDER_CTL_NO2,
		
		SUM(TOTAL_SHIP_AMT) AS TOTAL_SHIP_AMT2,
		SUM(DISCOUNT_AMT) as DISCOUNT_AMT2,
		SUM(TOT_NET_AMOUNT) AS TOT_NET_AMOUNT2,
		SUM(TOT_NET_COST) AS TOT_NET_COST2,
		SUM(TOTAL_FRT) AS TOTAL_FRT2,
		SUM(SALES_TAX_TOTAL) AS SALES_TAX_TOTAL2,
		SUM(OTHER_CHARGES) + SUM(RESTOCK_CHARGE) + SUM(TOTAL_VAS) AS OTHER2
		
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(SHIPPER_CTL_NO,5))
		) AS SH2
		
		ON AC.ITEMID = SH2.ITEM_ID
		
		
		LEFT JOIN
		(SELECT
		CONCAT(MI_LOC, SUBSTR(BILL_TO_CUST_NO,1,6)) AS MAX_CUSTPK,
		MAX(SALES_POSTED_DATE) AS LAST_ORDER
		FROM WHSE.SALES_USAGE_HDR_N
		GROUP BY CONCAT(MI_LOC, SUBSTR(BILL_TO_CUST_NO,1,6))
		) AS MC
		
		ON AC.CUSTACCTNO = MC.MAX_CUSTPK
		WITH UR"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "DATA", "Unknown", "Floyd _ Blu (motionhq_cd010325)", "From", "Load", "LEFT JOIN(DATA)
		LOAD
		DATE_KEY,
		CAD,
		MEX
		FROM [lib://QVD_FIN (motionhq_td020325)/Other/Excel/FX_N.xlsx]
		(ooxml, embedded labels, table is ***)", "LEFT JOIN(DATA)
		LOAD
		DATE_KEY,
		CAD,
		MEX
		FROM [lib://QVD_FIN (motionhq_td020325)/Other/Excel/FX_N.xlsx]
		(ooxml, embedded labels, table is ***)"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "DATA", "Unknown", "Floyd _ Blu (motionhq_cd010325)", "From", "Load", "LEFT JOIN(DATA)
		LOAD
		BAL_PK,
		1 as BAL_ADJ,
		BAL_CURR
		FROM [lib://QVD_FIN (motionhq_td020325)/App/AR_OPEN_INVOICES/CONV/MX.xlsx]
		(ooxml, embedded labels)", "LEFT JOIN(DATA)
		LOAD
		BAL_PK,
		1 as BAL_ADJ,
		BAL_CURR
		FROM [lib://QVD_FIN (motionhq_td020325)/App/AR_OPEN_INVOICES/CONV/MX.xlsx]
		(ooxml, embedded labels)"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "DATA_N", "DATA", "Floyd _ Blu (motionhq_cd010325)", "Resident", "Load", "Load
		*,
		IF([Past Due] = 1 AND DAYS_OUTSTANDING > 60, OUTSTGAMT) as OVER60_REPORT_AMT,
		IF(OUTSTGAMT > 5000 AND [Past Due] = 1, OUTSTGAMT) as PAST_DUE_5K_REPORT_AMT,
		IF([Past Due >90 = Freight] = 1, 'Past Due >90 = Freight',  IF([Past Due >90 = Tax] = 1, 'Past Due >90 = Tax', IF([Past Due >90 = Other] = 1, 'Past Due >90 = Other', IF([Past Due >90 = Discount AMT] = 1, 'Past Due > 90 = Discount Amt')))) as [Past Due >90 Flags],
		IF([Oustanding = Freight] = 1, 'Outstanding = Freight',  IF([Oustanding = Tax] = 1, 'Outstanding = Tax', IF([Oustanding = Other] = 1, 'Outstanding = Other', IF([Oustanding = Discount AMT] = 1, 'Outstanding = Discount Amt')))) as [Outstanding = AMT Flags]
		LOAD
		
		
		AR_BRACKET,
		DAYS_OUTSTANDING,
		CREDIT_BAL,
		
		IF(DAYS_OUTSTANDING  > 0 AND DAYS_OUTSTANDING <= 30, RGB(255, 216, 20),
		IF(DAYS_OUTSTANDING >= 30 AND DAYS_OUTSTANDING < 60, RGB (255, 161, 20),
		IF(DAYS_OUTSTANDING >= 60 AND DAYS_OUTSTANDING < 90, RGB(252, 55, 0),
		IF(DAYS_OUTSTANDING >= 90, RED())))) AS DAYS_OUTSTANDING_COLORS,
		
		CUSTOMER_NO_PK,
		OUTSTGAMT_CREDIT_BALANCE,
		NO_OUTSTANDING,
		AR_BRACKET_ORDER,
		AR_BRACKET_FULL,
		NOT_CORP,
		OUTSTANDING AS [Past Due],
		MI_CORP_LOC,
		DATE_KEY,
		""SUB"",
		BU,
		ITEMID,
		ITEMID as COMMENT_KEY,
		SHIPPER_CTL_NO,
		CUSTACCTNO & ITEMID AS DATA_PK,
		MI_LOC,
		
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60, 1,0) as OVER60_REPORT,
		IF(OUTSTGAMT > 5000 AND OUTSTANDING = 1, 1,0) as PAST_DUE_5K_REPORT,
		
		NUM(MONTH(INVDATE)) as INV_MONTH,
		YEAR(INVDATE) as INV_YEAR,
		INVDATE,
		DUEDATE,
		CUSTNAME,
		CUSTACCTNO,
		PO,
		ORIGAMT AS UNCONV_ORIGAMT,
		PAID_AMOUNT AS UNCONV_PAID_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', OUTSTGAMT * MEX, OUTSTGAMT),
		IF(MI_CORP_LOC = 'MX00', (OUTSTGAMT * MEX), IF(MI_CORP_LOC = 'CN00', (OUTSTGAMT * CAD), OUTSTGAMT)))
		AS OUTSTGAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', PAID_AMOUNT * MEX, PAID_AMOUNT),
		IF(MI_CORP_LOC = 'MX00', (PAID_AMOUNT * MEX), IF(MI_CORP_LOC = 'CN00', (PAID_AMOUNT * CAD), PAID_AMOUNT)))
		AS PAID_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DISCAMT * MEX, DISCAMT),
		IF(MI_CORP_LOC = 'MX00', (DISCAMT * MEX), IF(MI_CORP_LOC = 'CN00', (DISCAMT * CAD), DISCAMT)))
		AS DISCAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', ORIGAMT * MEX, ORIGAMT),
		IF(MI_CORP_LOC = 'MX00', (ORIGAMT * MEX), IF(MI_CORP_LOC = 'CN00', (ORIGAMT * CAD), ORIGAMT)))
		AS ORIGAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', CURRENT_AMT * MEX, CURRENT_AMT),
		IF(MI_CORP_LOC = 'MX00', (CURRENT_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (CURRENT_AMT * CAD), CURRENT_AMT)))
		AS CURRENT_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_1_30 * MEX, AMT_1_30),
		IF(MI_CORP_LOC = 'MX00', (AMT_1_30 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_1_30 * CAD), AMT_1_30)))
		AS AMT_1_30,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_31_60 * MEX, AMT_31_60),
		IF(MI_CORP_LOC = 'MX00', (AMT_31_60 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_31_60 * CAD), AMT_31_60)))
		AS AMT_31_60,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_61_90 * MEX, AMT_61_90),
		IF(MI_CORP_LOC = 'MX00', (AMT_61_90 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_61_90 * CAD), AMT_61_90)))
		AS AMT_61_90,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_90 * MEX, AMT_90),
		IF(MI_CORP_LOC = 'MX00', (AMT_90 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_90 * CAD), AMT_90)))
		AS AMT_90,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', PAST_DUE_AMT * MEX, PAST_DUE_AMT),
		IF(MI_CORP_LOC = 'MX00', (PAST_DUE_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (PAST_DUE_AMT * CAD), PAST_DUE_AMT)))
		AS PAST_DUE_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DUE_IN_30 * MEX, DUE_IN_30),
		IF(MI_CORP_LOC = 'MX00', (DUE_IN_30 * MEX), IF(MI_CORP_LOC = 'CN00', (DUE_IN_30 * CAD), DUE_IN_30)))
		AS DUE_IN_30,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOT_NET_AMOUNT * MEX, TOT_NET_AMOUNT),
		IF(MI_CORP_LOC = 'MX00', (TOT_NET_AMOUNT * MEX), IF(MI_CORP_LOC = 'CN00', (TOT_NET_AMOUNT * CAD), TOT_NET_AMOUNT)))
		AS TOT_NET_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOTAL_FRT * MEX, TOTAL_FRT),
		IF(MI_CORP_LOC = 'MX00', (TOTAL_FRT * MEX), IF(MI_CORP_LOC = 'CN00', (TOTAL_FRT * CAD), TOTAL_FRT)))
		AS TOTAL_FRT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', SALES_TAX_TOTAL * MEX, SALES_TAX_TOTAL),
		IF(MI_CORP_LOC = 'MX00', (SALES_TAX_TOTAL * MEX), IF(MI_CORP_LOC = 'CN00', (SALES_TAX_TOTAL * CAD), SALES_TAX_TOTAL)))
		AS SALES_TAX_TOTAL,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOTAL_SHIP_AMT * MEX, TOTAL_SHIP_AMT),
		IF(MI_CORP_LOC = 'MX00', (TOTAL_SHIP_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (TOTAL_SHIP_AMT * CAD), TOTAL_SHIP_AMT)))
		AS TOTAL_SHIP_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOT_NET_COST * MEX, TOT_NET_COST),
		IF(MI_CORP_LOC = 'MX00', (TOT_NET_COST * MEX), IF(MI_CORP_LOC = 'CN00', (TOT_NET_COST * CAD), TOT_NET_COST)))
		AS TOT_NET_COST,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', OTHER * MEX, OTHER),
		IF(MI_CORP_LOC = 'MX00', (OTHER * MEX), IF(MI_CORP_LOC = 'CN00', (OTHER * CAD), OTHER)))
		AS OTHER,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DISCOUNT_AMT * MEX, DISCOUNT_AMT),
		IF(MI_CORP_LOC = 'MX00', (DISCOUNT_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (DISCOUNT_AMT * CAD), DISCOUNT_AMT)))
		AS DISCOUNT_AMT,
		
		IF(round(OUTSTGAMT,.01) = round(TOTAL_FRT,0.01), 1) as [Oustanding = Freight],
		IF(round(OUTSTGAMT,.01) = round(SALES_TAX_TOTAL,0.01), 1) as [Oustanding = Tax],
		IF(round(OUTSTGAMT,.01) = round(OTHER,0.01), 1) as [Oustanding = Other],
		IF(round(OUTSTGAMT,.01) = round(DISCOUNT_AMT,0.01), 1) as [Oustanding = Discount AMT],
		
		IF(round(PAST_DUE_AMT,.01) = round(TOTAL_FRT,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Freight],
		IF(round(PAST_DUE_AMT,.01) = round(SALES_TAX_TOTAL,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Tax],
		IF(round(PAST_DUE_AMT,.01) = round(OTHER,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Other],
		IF(round(PAST_DUE_AMT,.01) = round(DISCOUNT_AMT,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Discount AMT],
		
		PAST_DUE_AMT as UNCONV_PAST_DUE_AMT,
		CURRENT_AMT as UNCONV_CURRENT_AMT,
		AMT_1_30 as UNCONV_AMT_1_30,
		AMT_31_60 as UNCONV_AMT_31_60,
		AMT_61_90 as UNCONV_AMT_61_90,
		AMT_90 as UNCONV_AMT_90,
		
		DUE_IN_30 as UNCONV_DUE_IN_30,
		OUTSTGAMT AS UNCONV_OUTSTGAMNT,
		DISCAMT AS UNCONV_DISCAMT,
		DISCDATE,
		DUE_IN_30_COUNT,
		NO_INVOICES,
		TODAY_DATE,
		ORDER_CTL_NO,
		DISCOUNT_AMT as UNCONV_DISCOUNT_AMT,
		TOTAL_SHIP_AMT as UNCONV_TOTAL_SHIP_AMT,
		TOT_NET_AMOUNT as UNCONV_TOT_NET_AMOUNT,
		TOT_NET_COST as UNCONV_TOT_NET_COST,
		TOTAL_FRT as UNCONV_TOTAL_FRT,
		SALES_TAX_TOTAL as UNCONV_SALES_TAX_TOTAL,
		OTHER as UNCONV_OTHER,
		LAST_ORDER
		
		RESIDENT DATA", "Load
		*,
		IF([Past Due] = 1 AND DAYS_OUTSTANDING > 60, OUTSTGAMT) as OVER60_REPORT_AMT,
		IF(OUTSTGAMT > 5000 AND [Past Due] = 1, OUTSTGAMT) as PAST_DUE_5K_REPORT_AMT,
		IF([Past Due >90 = Freight] = 1, 'Past Due >90 = Freight',  IF([Past Due >90 = Tax] = 1, 'Past Due >90 = Tax', IF([Past Due >90 = Other] = 1, 'Past Due >90 = Other', IF([Past Due >90 = Discount AMT] = 1, 'Past Due > 90 = Discount Amt')))) as [Past Due >90 Flags],
		IF([Oustanding = Freight] = 1, 'Outstanding = Freight',  IF([Oustanding = Tax] = 1, 'Outstanding = Tax', IF([Oustanding = Other] = 1, 'Outstanding = Other', IF([Oustanding = Discount AMT] = 1, 'Outstanding = Discount Amt')))) as [Outstanding = AMT Flags]
		LOAD
		
		
		AR_BRACKET,
		DAYS_OUTSTANDING,
		CREDIT_BAL,
		
		IF(DAYS_OUTSTANDING  > 0 AND DAYS_OUTSTANDING <= 30, RGB(255, 216, 20),
		IF(DAYS_OUTSTANDING >= 30 AND DAYS_OUTSTANDING < 60, RGB (255, 161, 20),
		IF(DAYS_OUTSTANDING >= 60 AND DAYS_OUTSTANDING < 90, RGB(252, 55, 0),
		IF(DAYS_OUTSTANDING >= 90, RED())))) AS DAYS_OUTSTANDING_COLORS,
		
		CUSTOMER_NO_PK,
		OUTSTGAMT_CREDIT_BALANCE,
		NO_OUTSTANDING,
		AR_BRACKET_ORDER,
		AR_BRACKET_FULL,
		NOT_CORP,
		OUTSTANDING AS [Past Due],
		MI_CORP_LOC,
		DATE_KEY,
		""SUB"",
		BU,
		ITEMID,
		ITEMID as COMMENT_KEY,
		SHIPPER_CTL_NO,
		CUSTACCTNO & ITEMID AS DATA_PK,
		MI_LOC,
		
		IF(OUTSTANDING = 1 AND DAYS_OUTSTANDING > 60, 1,0) as OVER60_REPORT,
		IF(OUTSTGAMT > 5000 AND OUTSTANDING = 1, 1,0) as PAST_DUE_5K_REPORT,
		
		NUM(MONTH(INVDATE)) as INV_MONTH,
		YEAR(INVDATE) as INV_YEAR,
		INVDATE,
		DUEDATE,
		CUSTNAME,
		CUSTACCTNO,
		PO,
		ORIGAMT AS UNCONV_ORIGAMT,
		PAID_AMOUNT AS UNCONV_PAID_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', OUTSTGAMT * MEX, OUTSTGAMT),
		IF(MI_CORP_LOC = 'MX00', (OUTSTGAMT * MEX), IF(MI_CORP_LOC = 'CN00', (OUTSTGAMT * CAD), OUTSTGAMT)))
		AS OUTSTGAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', PAID_AMOUNT * MEX, PAID_AMOUNT),
		IF(MI_CORP_LOC = 'MX00', (PAID_AMOUNT * MEX), IF(MI_CORP_LOC = 'CN00', (PAID_AMOUNT * CAD), PAID_AMOUNT)))
		AS PAID_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DISCAMT * MEX, DISCAMT),
		IF(MI_CORP_LOC = 'MX00', (DISCAMT * MEX), IF(MI_CORP_LOC = 'CN00', (DISCAMT * CAD), DISCAMT)))
		AS DISCAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', ORIGAMT * MEX, ORIGAMT),
		IF(MI_CORP_LOC = 'MX00', (ORIGAMT * MEX), IF(MI_CORP_LOC = 'CN00', (ORIGAMT * CAD), ORIGAMT)))
		AS ORIGAMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', CURRENT_AMT * MEX, CURRENT_AMT),
		IF(MI_CORP_LOC = 'MX00', (CURRENT_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (CURRENT_AMT * CAD), CURRENT_AMT)))
		AS CURRENT_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_1_30 * MEX, AMT_1_30),
		IF(MI_CORP_LOC = 'MX00', (AMT_1_30 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_1_30 * CAD), AMT_1_30)))
		AS AMT_1_30,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_31_60 * MEX, AMT_31_60),
		IF(MI_CORP_LOC = 'MX00', (AMT_31_60 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_31_60 * CAD), AMT_31_60)))
		AS AMT_31_60,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_61_90 * MEX, AMT_61_90),
		IF(MI_CORP_LOC = 'MX00', (AMT_61_90 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_61_90 * CAD), AMT_61_90)))
		AS AMT_61_90,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', AMT_90 * MEX, AMT_90),
		IF(MI_CORP_LOC = 'MX00', (AMT_90 * MEX), IF(MI_CORP_LOC = 'CN00', (AMT_90 * CAD), AMT_90)))
		AS AMT_90,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', PAST_DUE_AMT * MEX, PAST_DUE_AMT),
		IF(MI_CORP_LOC = 'MX00', (PAST_DUE_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (PAST_DUE_AMT * CAD), PAST_DUE_AMT)))
		AS PAST_DUE_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DUE_IN_30 * MEX, DUE_IN_30),
		IF(MI_CORP_LOC = 'MX00', (DUE_IN_30 * MEX), IF(MI_CORP_LOC = 'CN00', (DUE_IN_30 * CAD), DUE_IN_30)))
		AS DUE_IN_30,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOT_NET_AMOUNT * MEX, TOT_NET_AMOUNT),
		IF(MI_CORP_LOC = 'MX00', (TOT_NET_AMOUNT * MEX), IF(MI_CORP_LOC = 'CN00', (TOT_NET_AMOUNT * CAD), TOT_NET_AMOUNT)))
		AS TOT_NET_AMOUNT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOTAL_FRT * MEX, TOTAL_FRT),
		IF(MI_CORP_LOC = 'MX00', (TOTAL_FRT * MEX), IF(MI_CORP_LOC = 'CN00', (TOTAL_FRT * CAD), TOTAL_FRT)))
		AS TOTAL_FRT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', SALES_TAX_TOTAL * MEX, SALES_TAX_TOTAL),
		IF(MI_CORP_LOC = 'MX00', (SALES_TAX_TOTAL * MEX), IF(MI_CORP_LOC = 'CN00', (SALES_TAX_TOTAL * CAD), SALES_TAX_TOTAL)))
		AS SALES_TAX_TOTAL,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOTAL_SHIP_AMT * MEX, TOTAL_SHIP_AMT),
		IF(MI_CORP_LOC = 'MX00', (TOTAL_SHIP_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (TOTAL_SHIP_AMT * CAD), TOTAL_SHIP_AMT)))
		AS TOTAL_SHIP_AMT,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', TOT_NET_COST * MEX, TOT_NET_COST),
		IF(MI_CORP_LOC = 'MX00', (TOT_NET_COST * MEX), IF(MI_CORP_LOC = 'CN00', (TOT_NET_COST * CAD), TOT_NET_COST)))
		AS TOT_NET_COST,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', OTHER * MEX, OTHER),
		IF(MI_CORP_LOC = 'MX00', (OTHER * MEX), IF(MI_CORP_LOC = 'CN00', (OTHER * CAD), OTHER)))
		AS OTHER,
		
		IF(BAL_ADJ = 1, IF(BAL_CURR = 'MXN', DISCOUNT_AMT * MEX, DISCOUNT_AMT),
		IF(MI_CORP_LOC = 'MX00', (DISCOUNT_AMT * MEX), IF(MI_CORP_LOC = 'CN00', (DISCOUNT_AMT * CAD), DISCOUNT_AMT)))
		AS DISCOUNT_AMT,
		
		IF(round(OUTSTGAMT,.01) = round(TOTAL_FRT,0.01), 1) as [Oustanding = Freight],
		IF(round(OUTSTGAMT,.01) = round(SALES_TAX_TOTAL,0.01), 1) as [Oustanding = Tax],
		IF(round(OUTSTGAMT,.01) = round(OTHER,0.01), 1) as [Oustanding = Other],
		IF(round(OUTSTGAMT,.01) = round(DISCOUNT_AMT,0.01), 1) as [Oustanding = Discount AMT],
		
		IF(round(PAST_DUE_AMT,.01) = round(TOTAL_FRT,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Freight],
		IF(round(PAST_DUE_AMT,.01) = round(SALES_TAX_TOTAL,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Tax],
		IF(round(PAST_DUE_AMT,.01) = round(OTHER,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Other],
		IF(round(PAST_DUE_AMT,.01) = round(DISCOUNT_AMT,0.01), IF(DAYS_OUTSTANDING >= 90, 1)) as [Past Due >90 = Discount AMT],
		
		PAST_DUE_AMT as UNCONV_PAST_DUE_AMT,
		CURRENT_AMT as UNCONV_CURRENT_AMT,
		AMT_1_30 as UNCONV_AMT_1_30,
		AMT_31_60 as UNCONV_AMT_31_60,
		AMT_61_90 as UNCONV_AMT_61_90,
		AMT_90 as UNCONV_AMT_90,
		
		DUE_IN_30 as UNCONV_DUE_IN_30,
		OUTSTGAMT AS UNCONV_OUTSTGAMNT,
		DISCAMT AS UNCONV_DISCAMT,
		DISCDATE,
		DUE_IN_30_COUNT,
		NO_INVOICES,
		TODAY_DATE,
		ORDER_CTL_NO,
		DISCOUNT_AMT as UNCONV_DISCOUNT_AMT,
		TOTAL_SHIP_AMT as UNCONV_TOTAL_SHIP_AMT,
		TOT_NET_AMOUNT as UNCONV_TOT_NET_AMOUNT,
		TOT_NET_COST as UNCONV_TOT_NET_COST,
		TOTAL_FRT as UNCONV_TOTAL_FRT,
		SALES_TAX_TOTAL as UNCONV_SALES_TAX_TOTAL,
		OTHER as UNCONV_OTHER,
		LAST_ORDER
		
		RESIDENT DATA"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "", "", "Floyd _ Blu (motionhq_cd010325)", "None", "DropTable", "DROP TABLE DATA
		", "DROP TABLE DATA
