expression fx_DistinctKeyChecker = ```
		let
		    //This is a comment
		    fx = (p_KeyField as list) => let
		        #"Converted to Table"            = Table.FromList(p_KeyField, Splitter.SplitByNothing(), {"Key"}, null, ExtraValues.Error),
		        #"Grouped Rows"                  = Table.Group(#"Converted to Table", {"Key"}, {{"Count", each Table.RowCount(_), Int64.Type}}),
		        #"Select Rows"                   = Table.SelectRows(#"Grouped Rows", each [Count] > 1),
		        Error                            = error Error.Record(
		                                                "Errors were found in a key field"
		                                                , "Key field exists on multiple records"
		                                                , "Check key field for duplicates"
		                                                ),
		        #"Add Error Column"             = Table.AddColumn(#"Select Rows", "Error", each Error),
		        Output                          = #"Add Error Column"
		    in
		        Output
		        , fx_Type = type function
		        (
		            p_KeyField as list
		        ) as table meta
		        [
		            Documentation.Name          = "fx_DistinctKeyChecker"
		            , Documentation.Description = "This function is intended to identify key values that are expected to be unique to each row and determine if it is truly unique. If it is not, this function will generate a table with the key values that are in violation, and throw an error in the data refresh"
		            , Documentation.Examples    = 
		            {
		                [
		                    Description         = "Example usage of fx_DistinctKeyChecker"
		                    , Code              = "fx_DistinctKeyChecker(Sales[Order Number])"
		                    , Result            = "A table with all the Order Numbers that appear on multiple records in the Sales table."
		                ]
		            }
		        ]
		in
		Value.ReplaceType(fx, fx_Type)
		```
