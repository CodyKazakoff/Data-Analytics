expression fx_ConditionallyLimitRows = ```
		let
		  fx = (p_Table as table, p_LimitRecords as logical, p_RecordCount as number) => let
		        Output                          = if p_LimitRecords
		                                            then Table.FirstN(p_Table, p_RecordCount)
		                                            else p_Table
		    in
		        Output,
		  fx_Type = type function
		        (
		            p_Table as table
		            , p_LimitRecords as logical
		            , p_RecordCount as number
		        ) as table meta
		        [
		            Documentation.Name          = "fx_ConditionallyLimitRows"
		            , Documentation.Description = "This function will conditionally limit the records based on the logical p_LimitRecords. This function is foldable, you'll see the native query for this step in your query's applied steps."
		            , Documentation.Examples    = 
		            {
		                [
		                    Description         = "Example usage of fx_ConditionallyLimitRows, limiting record to the first 10."
		                    , Code              = "fx_ConditionallyLimitRows(#""Table"", true, 10)"
		                    , Result            = "The top 10 records for table ""#Table"""
		                ]
		            }
		        ],
		  fx_Output = Value.ReplaceType(fx, fx_Type)
		in
		  fx_Output
		```
