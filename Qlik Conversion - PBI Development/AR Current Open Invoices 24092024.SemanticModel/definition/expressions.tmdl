		MAXSTRING(NAME) as NAME,
		MAXSTRING(PARENT_COMPANY) as PARENT_COMPANY,
		MAXSTRING(CONTRACT_FLAG) as CONTRACT_FLAG
		FROM [lib://QVD_FIN (motionhq_td020325)/Dimension/NATIONAL_ACCOUNT.qvd]
		(qvd)
		GROUP BY NATL_KEY"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "CUSTOMER_BT", "Unknown", "Floyd _ Blu (motionhq_cd010325)", "From", "Load", "LEFT JOIN(CUSTOMER_BT)
		LOAD
		PAY_CORP & PAY_PMNT_TERM as PAYPK,
		*
		LOAD
		IF(CORP_CD = 1, 'AL00', IF(CORP_CD = 2, 'CN00', IF(CORP_CD = 3, 'MX00', IF(CORP_CD = 4, 'AS00', IF(CORP_CD = 5, 'PI00', IF(CORP_CD = 6, 'SH00', CORP_CD)))))) as PAY_CORP,
		CORP_CD as PAY_CORP_CD,
		PYMNT_TERM as PAY_PMNT_TERM,
		DESCRIPTION as PAY_DESC,
		CALENDAR as PAY_CALDENDAR,
