		LOAD
			CUSTACCTNO,
		    AVG([Avg Days to Pay]) AS [Avg Days to Pay]
		    
		GROUP BY CUSTACCTNO;NOCONCATENATE LOAD 
			CUST_PK as CUSTACCTNO,
		    INVOICE_DT,
		    ITEMID,
		    PAID_DT,
		    PAID_DT - INVOICE_DT as [Avg Days to Pay]
		    
		WHERE NOT ISNULL(PAID_DT)
		;SQL SELECT
			SH.CUST_PK,
		    SH.INVOICE_DT,
		    SH.ITEMID,
		    PD.PAID_DT	
		    
		    FROM (SELECT	
		    	CONCAT(MI_LOC, SUBSTR(CUSTOMER_NO,1,6)) AS CUST_PK,
		        CONCAT(MI_LOC, SHIPPER_CTL_NO) AS ITEMID,
		        MAX(SALES_POSTED_DATE) AS INVOICE_DT
		        FROM WHSE.SALES_USAGE_HDR_N
		        WHERE SALES_POSTED_DATE >= '08/01/2020' 
		    	GROUP BY 
		        	CONCAT(MI_LOC, SUBSTR(CUSTOMER_NO,1,6)),
		        	CONCAT(MI_LOC, SHIPPER_CTL_NO)
		        
		    ) AS SH
		    
		    LEFT JOIN (SELECT
		    	ITEM AS ITEMID,
		        MAX(ACCOUNTING_DT) AS PAID_DT
		        FROM EDW_FIN.INTAR0099
		        WHERE ACCOUNTING_DT >= '01/01/2020'
		        AND ENTRY_TYPE IN ('PY')
		        GROUP BY ITEM
		    ) AS PD
		    
		    ON SH.ITEMID = PD.ITEMID
		    
		    
		WITH UR", "N/A"}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3.598a1aab-e26f-46bb-ad8b-b6631e85f26c", "598a1aab-e26f-46bb-ad8b-b6631e85f26c", "Load", "Floyd _ Blu (motionhq_cd010325)", "CR_ANALYST:
