		START_POINT as PAY_START_POINT,
		DISABLED as PAY_DISABLED,
		LAST_UPD_USERID as PAY_LAST_UPD_USERID,
		LAST_UPD_TMSTMP as PAY_LAST_UPD_TMSTMP
		SELECT ""CORP_CD"",
		""PYMNT_TERM"",
		""DESCRIPTION"",
		""CALENDAR"",
		""STLMNT_DAYS"",
		""START_POINT"",
		""DISABLED"",
		""LAST_UPD_USERID"",
		""LAST_UPD_TMSTMP""
		FROM ""CUST"".""PAYMENT_TERMS""", "LEFT JOIN(CUSTOMER_BT)
		LOAD
		PAY_CORP & PAY_PMNT_TERM as PAYPK,
		*
		LOAD
		IF(CORP_CD = 1, 'AL00', IF(CORP_CD = 2, 'CN00', IF(CORP_CD = 3, 'MX00', IF(CORP_CD = 4, 'AS00', IF(CORP_CD = 5, 'PI00', IF(CORP_CD = 6, 'SH00', CORP_CD)))))) as PAY_CORP,
		CORP_CD as PAY_CORP_CD,
		PYMNT_TERM as PAY_PMNT_TERM,
		DESCRIPTION as PAY_DESC,
		CALENDAR as PAY_CALDENDAR,
		STLMNT_DAYS as PAY_STLMNT_DAYS,
		START_POINT as PAY_START_POINT,
		DISABLED as PAY_DISABLED,
		LAST_UPD_USERID as PAY_LAST_UPD_USERID,
		LAST_UPD_TMSTMP as PAY_LAST_UPD_TMSTMP
		SELECT ""CORP_CD"",
		""PYMNT_TERM"",
		""DESCRIPTION"",
		""CALENDAR"",
		""STLMNT_DAYS"",
		""START_POINT"",
		""DISABLED"",
		""LAST_UPD_USERID"",
		""LAST_UPD_TMSTMP""
		FROM ""CUST"".""PAYMENT_TERMS"""}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "CUSTOMER_BT", "Unknown", "Floyd _ Blu (motionhq_cd010325)", "From", "Load", "LEFT JOIN(CUSTOMER_BT)
		LOAD
		DISC_CORP & DISC_DSCNT_TERM as DISCPK,
		*
		LOAD
		IF(CORP_CD = 1, 'AL00', IF(CORP_CD = 2, 'CN00', IF(CORP_CD = 3, 'MX00', IF(CORP_CD = 4, 'AS00', IF(CORP_CD = 5, 'PI00', IF(CORP_CD = 6, 'SH00', CORP_CD)))))) as DISC_CORP,
		CORP_CD as DISC_CORP_CD,
		DSCNT_TERM AS DISC_DSCNT_TERM,
		DESCRIPTION AS DISC_DESCRIPTION,
		CALENDAR AS DISC_CALENDAR,
		START_POINT AS DISC_START_POINT,
		DSCNT_PERCNT AS DISC_DSCNT_PERCNT,
		DSCNT_DAYS AS DISC_DSCNT_DAYS,
		DISABLED AS DISC_DISABLED,
		LAST_UPD_USERID AS DISC_LAST_UPD_USERID,
		LAST_UPD_TMSTMP AS DISC_LAST_UPD_TMSTMP,
		CREATION_USERID AS DISC_CREATION_USERID
		SELECT ""CORP_CD"",
		""DSCNT_TERM"",
		""DESCRIPTION"",
		""CALENDAR"",
		""START_POINT"",
		""DSCNT_PERCNT"",
		""DSCNT_DAYS"",
		""DISABLED"",
		""LAST_UPD_USERID"",
		""LAST_UPD_TMSTMP"",
		""CREATION_USERID""
		FROM ""CUST"".""DISCOUNT_TERMS""", "LEFT JOIN(CUSTOMER_BT)
		LOAD
		DISC_CORP & DISC_DSCNT_TERM as DISCPK,
		*
		LOAD
		IF(CORP_CD = 1, 'AL00', IF(CORP_CD = 2, 'CN00', IF(CORP_CD = 3, 'MX00', IF(CORP_CD = 4, 'AS00', IF(CORP_CD = 5, 'PI00', IF(CORP_CD = 6, 'SH00', CORP_CD)))))) as DISC_CORP,
		CORP_CD as DISC_CORP_CD,
		DSCNT_TERM AS DISC_DSCNT_TERM,
		DESCRIPTION AS DISC_DESCRIPTION,
		CALENDAR AS DISC_CALENDAR,
		START_POINT AS DISC_START_POINT,
		DSCNT_PERCNT AS DISC_DSCNT_PERCNT,
		DSCNT_DAYS AS DISC_DSCNT_DAYS,
		DISABLED AS DISC_DISABLED,
		LAST_UPD_USERID AS DISC_LAST_UPD_USERID,
		LAST_UPD_TMSTMP AS DISC_LAST_UPD_TMSTMP,
		CREATION_USERID AS DISC_CREATION_USERID
		SELECT ""CORP_CD"",
		""DSCNT_TERM"",
		""DESCRIPTION"",
		""CALENDAR"",
		""START_POINT"",
		""DSCNT_PERCNT"",
		""DSCNT_DAYS"",
		""DISABLED"",
		""LAST_UPD_USERID"",
		""LAST_UPD_TMSTMP"",
		""CREATION_USERID""
		FROM ""CUST"".""DISCOUNT_TERMS"""}, {"c16c9bb1-62b8-4f31-af39-2dbac267c9e3", "DATA_N", "CUSTOMER_BT", "Floyd _ Blu (motionhq_cd010325)", "Resident", "Load", "LEFT JOIN(DATA_N)
		LOAD *,
		IF(CONTRACT_FLAG = 'Y', [Customer]) as [Contract CustRollup],
		IF(ISNULL([National Acct]), '', [National Acct]) as [National Acct No],
		IF(ISNULL(NAME),'',NAME) as [National Acct Name]
		LOAD *,
		IF(ISNULL(BRA_ASSIGNED), 'N/A', BRA_ASSIGNED) as [BRA Assigned],
		IF(1=0, 0,1) as [Exclude Assignment],
		IF(ISNULL(PARENT_COMPANY), '', PARENT_COMPANY) as PARENT_COMPANY_N,
		IF(ISNULL(DISC_DESCRIPTION), '', DISC_DESCRIPTION) AS [Disc Desc],
		IF(ISNULL(DISC_DSCNT_DAYS), '', DISC_DSCNT_DAYS) AS [Disc Days],
		IF(ISNULL(DISC_DSCNT_PERCNT), '', DISC_DSCNT_PERCNT) AS [Disc Percent],
		IF(ISNULL(PARENT_COMPANY), CUSTOMER_NAME, PARENT_COMPANY) as [Customer],
		IF(len(TRIM(NATL_ACCT_NO)) < 2, 'All Non-Natl Acct', 'All Natl Accts') as IS_NATLACCT,
		IF(NATL_ACCT_NO >0, NATL_KEY) as [National Acct],
		IF(ISNULL(NAME), NATL_KEY, NATL_KEY & ' - ' & NAME) as [Natl Account Full],
		
		IF(ISNULL(NATL_ASSIGNMENT), 'Non BRA Assigned', 'BRA Assigned') as [Natl Assignments],
		IF(ISNULL(NATL_ASSIGNMENT) AND LEN(TRIM(NATL_KEY)) > 4, 'Unassigned Natl Accounts', IF(NOT ISNULL(NATL_ASSIGNMENT), NATL_ASSIGNMENT)) as [Non Natl Assignment],
		IF(CONTRACT_FLAG = 'Y', 'Contracted Customers', 'Non-Contracted Customers') as [Contracted Customers],
		IF(isnull(CONTRACT_FLAG), 'N', 'Y') as [Contract Flag]
		
		RESIDENT CUSTOMER_BT", "LEFT JOIN(DATA_N)
		LOAD *,
		IF(CONTRACT_FLAG = 'Y', [Customer]) as [Contract CustRollup],
		IF(ISNULL([National Acct]), '', [National Acct]) as [National Acct No],
		IF(ISNULL(NAME),'',NAME) as [National Acct Name]
		LOAD *,
		IF(ISNULL(BRA_ASSIGNED), 'N/A', BRA_ASSIGNED) as [BRA Assigned],
		IF(1=0, 0,1) as [Exclude Assignment],
		IF(ISNULL(PARENT_COMPANY), '', PARENT_COMPANY) as PARENT_COMPANY_N,
		IF(ISNULL(DISC_DESCRIPTION), '', DISC_DESCRIPTION) AS [Disc Desc],
		IF(ISNULL(DISC_DSCNT_DAYS), '', DISC_DSCNT_DAYS) AS [Disc Days],
		IF(ISNULL(DISC_DSCNT_PERCNT), '', DISC_DSCNT_PERCNT) AS [Disc Percent],
		IF(ISNULL(PARENT_COMPANY), CUSTOMER_NAME, PARENT_COMPANY) as [Customer],
		IF(len(TRIM(NATL_ACCT_NO)) < 2, 'All Non-Natl Acct', 'All Natl Accts') as IS_NATLACCT,
		IF(NATL_ACCT_NO >0, NATL_KEY) as [National Acct],
		IF(ISNULL(NAME), NATL_KEY, NATL_KEY & ' - ' & NAME) as [Natl Account Full],
		
		IF(ISNULL(NATL_ASSIGNMENT), 'Non BRA Assigned', 'BRA Assigned') as [Natl Assignments],
