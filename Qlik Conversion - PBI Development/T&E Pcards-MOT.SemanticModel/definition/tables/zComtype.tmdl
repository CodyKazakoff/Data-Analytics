	column Comtype = ```
			
			SWITCH(
			    TRUE(),
			    SEARCH("CMFuel", 'zComtype'[zComtype], 1, 0) > 0, "Prior 3MA vs CM",
			    SEARCH("3MAFuel", 'zComtype'[zComtype], 1, 0) > 0, "Prior 3MA vs 3MA",
			    SEARCH("Ppg", 'zComtype'[zComtype], 1, 0) > 0, "CM vs Prior 3MA PPG",
			    SEARCH("Gal", 'zComtype'[zComtype], 1, 0) > 0, "CM vs Prior 3MA Gal"
			   
			)
			```
		lineageTag: 21eb5863-d2e9-40f6-a37e-cca2fbfb019e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition zComtype = calculated
		mode: import
		source =
				{
				    ("Prior 3MAFuel", NAMEOF('Measure Table'[Prior 3MAFuel]), 0),
				    ("Prior 3MA/CMFuel", NAMEOF('Measure Table'[Prior3MAvsCMFuel]), 1),
				    ("Prior 3MA(PPG)", NAMEOF('Measure Table'[Prior 3MA(PPG)]), 2),
				    ("Prior 3MA(Gal)", NAMEOF('Measure Table'[Prior 3MA(Gal)]), 3),
				    ("CMFuel", NAMEOF('Measure Table'[CMFuel Amount]), 4),
