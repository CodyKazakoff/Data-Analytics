	measure 'Workdays Since Refresh' =
			
			
			VAR vGbqRefresh = MAX('refresh_log'[Most Stale Source Table Tmstmp])
			
			VAR vFabricRefresh = MAX('refresh_log'[Run Complete Time])
			
			-- Want to count the number of WHOLE days have passed. To do this, we're truncating the hours, minutes, and seconds fields
			VAR vResult = NETWORKDAYS(
			    DATE(YEAR(vGbqRefresh), MONTH(vGbqRefresh), DAY(vGbqRefresh))
			    , DATE(YEAR(vFabricRefresh), MONTH(vFabricRefresh), DAY(vFabricRefresh))
			)
			RETURN IF(vResult > 30000, 0, vResult) - 1 -- Adjusting by 1 since refreshes are expected to ~1 day behing anyways. Fields which don't have refresh dates will populate -1 which is intended
			// RETURN vResult
		formatString: 0
		displayFolder: Refresh Log Measures
		lineageTag: 9d9235e3-5c30-4695-9b8e-db6ba5c5454b

