	measure '# of New Failures' = ```
			
			
			VAR TODAYDATE = MAX('data_quality_testing'[TIMESTAMP])
			VAR YesterdayPassing =
			   CALCULATETABLE(
			       DISTINCT(
			        SELECTCOLUMNS
			        ('data_quality_testing', "JOB", 
			       'data_quality_testing'[TEST_CASE_NAME],
			       'data_quality_testing'[TEST_TYPE],
			       'data_quality_testing'[TABLE_NAME]
			       )
			    ),
			       'data_quality_testing'[PASS_FLAG] = TRUE,
			       'data_quality_testing'[TIMESTAMP] = TODAYDATE - 1
			   )
			VAR TodayFailing =
			   CALCULATETABLE(
			       DISTINCT(
			        SELECTCOLUMNS(
			        'data_quality_testing', "JOB", 
			        'data_quality_testing'[TEST_CASE_NAME],
			        'data_quality_testing'[TEST_TYPE],
			        'data_quality_testing'[TABLE_NAME]
			       )
			    ),
			       'data_quality_testing'[PASS_FLAG] = FALSE,
			       'data_quality_testing'[TIMESTAMP] = TODAYDATE
			   )
			
			VAR NewFailuresCount =
			    COUNTROWS(
			        EXCEPT(
			            TodayFailing,
			            YesterdayPassing
			        )
			    )
			RETURN
			IF (ISBLANK(NewFailuresCount),0,NewFailuresCount)
			```
		formatString: 0
		lineageTag: a20250a7-8b9b-4ff2-8b16-f622a1af2e6e

	measure '% Change in Failed Jobs' = ```
			
			VAR FailedToday =
			   CALCULATE(
			       COUNTA('data_quality_testing'[RESULT]),
			       FILTER(
			           'data_quality_testing',
			           'data_quality_testing'[PASS_FLAG] = FALSE &&
			           'data_quality_testing'[TIMESTAMP] = TODAY()
			       )
			   )
			VAR FailedYesterday =
			   CALCULATE(
			       COUNTA('data_quality_testing'[RESULT]),
			       FILTER(
			           'data_quality_testing',
			           'data_quality_testing'[PASS_FLAG] = FALSE &&
			           'data_quality_testing'[TIMESTAMP] = TODAY() - 1
			       )
			   )
			RETURN
			IF(FailedYesterday = 0, 
			    IF(FailedToday= 0,0,BLANK()), (FailedToday - FailedYesterday) / FailedYesterday * 100)
			```
		formatString: 0
		lineageTag: 75b241ff-0f6b-4dd2-ae29-1ac9d9de7379

	measure '% 24h Failed Test Cases' = ```
			
			    IF(
			        ISBLANK([24h Total Test Cases]) || [24h Total Test Cases] = 0, 
			        BLANK(), 
			        IF(
			            DIVIDE([24h Total Failed Test Cases], [24h Total Test Cases]) = 0,
			            BLANK(),
			            DIVIDE([24h Total Failed Test Cases], [24h Total Test Cases])
			        )
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6df7720d-9d15-45e3-a1c9-d4b68d1bcc93

	measure '% of Jobs Failed' =
			
			VAR __MEASURE_VALUE =
				CALCULATE(
					COUNTA('data_quality_testing'[RESULT]),
					'data_quality_testing'[PASS_FLAG] IN { FALSE }
				)
			VAR __BASELINE_VALUE = COUNTA('data_quality_testing'[RESULT])
			RETURN
				IF(
					NOT ISBLANK(__MEASURE_VALUE),
					DIVIDE(__MEASURE_VALUE, __BASELINE_VALUE)
				)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d3f7e5b2-a5a2-4528-a040-3c51231407d8

