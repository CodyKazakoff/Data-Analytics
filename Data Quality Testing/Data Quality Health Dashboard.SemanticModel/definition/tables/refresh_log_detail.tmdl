	partition refresh_log_detail = m
		mode: import
		source = ```
				let
				    Source = Sql.Database(Lakehouse & ".datawarehouse.fabric.microsoft.com", "Enterprise_Analytics"),
				    dbo_refresh_log_detail = Value.NativeQuery(Source, "
				    SELECT 
				        SOURCE_TABLE
				        , REFINED_VIEW_DEPENDENCY
				        , TABLE_TYPE
				        , LAST_REFRESH --AT TIME ZONE 'UTC' AT TIME ZONE 'Central Standard Time' AS [LAST_REFRESH]
				        , REFRESH_LOG_HDR_KEY 
				    FROM refresh_log_detail
				    ", null, [EnableFolding = true]),
				    #"Bulk Column Rename" = Table.TransformColumnNames(dbo_refresh_log_detail, each Text.Combine(List.ReplaceMatchingItems(List.Transform(Text.Split(_,"_"), Text.Proper),{{"Id","ID"}, {"Mi", "MI"}, {"Upn", "UPN"}, {"Usd", "USD"}})," "))
				in
				    #"Bulk Column Rename"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

