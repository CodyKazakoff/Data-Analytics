	partition 'Fact Table Date Range' = m
		mode: import
		queryGroup: Dimensions
		source = ```
				let
				    Source = F_SHPR_P21, /*Replace F_Shipper_Item with the name of the fact table*/
				    #"CalculateMinMaxDates" = Table.Group(Source, {}, 
				      {{"Max Transaction Date", each List.Max([SHIP_DATE]), type nullable date}, 
				      {"Min Transaction Date", each List.Min([SHIP_DATE]), type nullable date}}) /*Replace SHIP_DATE with the name of the date field in the fact table*/
				in
				    #"CalculateMinMaxDates"
				```

