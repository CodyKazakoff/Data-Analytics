	measure Prior3MAvsCMFuel =
			
			VAR LatestDate = MAX('F_Fleet_Expenses'[Date])
			VAR EndOfLastMonth = EOMONTH(LatestDate, -3)
			VAR StartOfThreeMonthsAgo = EOMONTH(LatestDate, -6) + 1
			RETURN
			CALCULATE(
			    Divide(SUM(F_Fleet_Expenses[FuelAmount]) + SUM(F_Fleet_Expenses[MiscAmount]),3),
			    FILTER(
			        'D_Calendar',
			        'D_Calendar'[CALENDAR_DATE] >= StartOfThreeMonthsAgo &&
			        'D_Calendar'[CALENDAR_DATE] <= EndOfLastMonth
