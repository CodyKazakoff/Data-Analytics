/// Sum of total Reportable Accidents
table 'Measure Table'
	lineageTag: ce2aa14d-6693-4b71-be30-f49cd138f021

	/// Refresh Date for Loss Run Report
	measure 'Report Refresh Date' = "Report as of: " & Max('zLast Refresh Datetime'[Last Refresh Datetime])
		displayFolder: Metadata
		lineageTag: 2360455c-966c-4ea4-af74-a5137572a971

	measure Amount = Sum('F_T&E PCards 1'[Amount])
		formatString: #,0
		lineageTag: e6e17a5c-9255-4d3b-ad5f-9eebfd63741c

	measure Price/Gall = DIVIDE(Sum(F_Fleet_Expenses[FuelAmount]),Sum(F_Fleet_Expenses[Gallons]))
		lineageTag: d22c9068-23a0-4ccc-b2ad-3b75941e8867

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 3MA =
			
			CALCULATE(
			    Divide(Sum('F_T&E PCards 1'[Amount]), 3),
			    DATESINPERIOD(
			        'F_T&E PCards 1'[Date],
			        MAX('F_T&E PCards 1'[Date]),
			        -3,
			        MONTH
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: 3MA
		lineageTag: 7feed3fa-9104-42ea-a22e-227129e7baaf

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'CM Amount' =
			
			VAR LatestMonth = MAX('F_T&E PCards 1'[Date])
			RETURN
			CALCULATE(
			    SUM('F_T&E PCards 1'[Amount]),
			    FILTER(
			        'D_Calendar',
			        MONTH('D_Calendar'[CALENDAR_DATE]) = MONTH(LatestMonth) &&
			        YEAR(D_Calendar[CALENDAR_DATE]) = YEAR(LatestMonth)
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: CM
		lineageTag: f4a69649-e94a-4b8f-a6d0-e63c98988ec4

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Prior 3MA' =
			
			VAR LatestDate = MAX('F_T&E PCards 1'[Date])
			VAR EndOfLastMonth = EOMONTH(LatestDate, -3)
			VAR StartOfThreeMonthsAgo = EOMONTH(LatestDate, -6) + 1
			RETURN
			CALCULATE(
			    Divide(SUM('F_T&E PCards 1'[Amount]),3),
			    FILTER(
			        'D_Calendar',
			        'D_Calendar'[CALENDAR_DATE] >= StartOfThreeMonthsAgo &&
			        'D_Calendar'[CALENDAR_DATE] <= EndOfLastMonth
			    )
			)
		formatString: #,0
		lineageTag: 91df62ab-5cbe-4942-a774-d198e1124194

		annotation PBI_FormatHint = {"isDecimal":true}

	measure '$Change.CM' = [CM Amount]- [Prior 3MA]
		formatString: #,0
		displayFolder: CM
		lineageTag: 70d7b282-bab6-4049-9fe2-846d3bce5c93

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Comdata AMT' = CALCULATE(Sum(F_Fleet_Expenses[FuelAmount]) + Sum(F_Fleet_Expenses[MiscAmount]))
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 1a3f6408-28d8-466e-9479-bf04fbfd2a83

	measure 'CMFuel Amount' =
			
			VAR LatestMonth = MAX('F_Fleet_Expenses'[Date])
			RETURN
			CALCULATE(
			    (SUM('F_Fleet_Expenses'[FuelAmount])+ SUM(F_Fleet_Expenses[MiscAmount])),
			    FILTER(
			        'D_Calendar',
			        MONTH('D_Calendar'[CALENDAR_DATE]) = MONTH(LatestMonth) &&
			        YEAR(D_Calendar[CALENDAR_DATE]) = YEAR(LatestMonth)
			    )
			)
		formatString: #,0
		displayFolder: CMFuel
		lineageTag: 036ea3dc-377c-4fd4-ba03-dc25a5a7f6ac

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Prior 3MAFuel' =
			
			VAR LatestDate = MAX('F_Fleet_Expenses'[Date])
			VAR EndOfLastMonth = EOMONTH(LatestDate, -3)
			VAR StartOfThreeMonthsAgo = EOMONTH(LatestDate, -6) + 1
			RETURN
			CALCULATE(
			    Divide(SUM(F_Fleet_Expenses[FuelAmount]) + SUM(F_Fleet_Expenses[MiscAmount]),3),
			    FILTER(
			        'D_Calendar',
			        'D_Calendar'[CALENDAR_DATE] >= StartOfThreeMonthsAgo &&
			        'D_Calendar'[CALENDAR_DATE] <= EndOfLastMonth
			    )
			)
		formatString: #,0
		displayFolder: 3MA Fuel
		lineageTag: ff2100f6-00fd-401b-8874-2e8cb3d40d3f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 3MAFuel =
			
			CALCULATE(
			    Divide(Sum('F_Fleet_Expenses'[FuelAmount]) + SUM(F_Fleet_Expenses[MiscAmount]), 3),
			    DATESINPERIOD(
			        'F_Fleet_Expenses'[Date],
			        MAX('F_Fleet_Expenses'[Date]),
			        -3,
			        MONTH
			    ))
		formatString: #,0
		displayFolder: 3MA Fuel
		lineageTag: 29ef8884-40f2-424c-afe4-29425abecd34

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'CM Amount(Gal)' =
			
			VAR LatestMonth = MAX('F_Fleet_Expenses'[Date])
			RETURN
			CALCULATE(
			    (SUM('F_Fleet_Expenses'[Gallons])),
			    FILTER(
			        'D_Calendar',
			        MONTH('D_Calendar'[CALENDAR_DATE]) = MONTH(LatestMonth) &&
			        YEAR(D_Calendar[CALENDAR_DATE]) = YEAR(LatestMonth)
			    )
			)
		formatString: #,0
		displayFolder: Gal
		lineageTag: 8fdbf84e-864e-4a55-adc6-f48b18146930

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Prior 3MA(Gal)' =
			
			VAR LatestDate = MAX('F_Fleet_Expenses'[Date])
			VAR EndOfLastMonth = EOMONTH(LatestDate, -3)
			VAR StartOfThreeMonthsAgo = EOMONTH(LatestDate, -6) + 1
			RETURN
			CALCULATE(
			    Divide(SUM(F_Fleet_Expenses[Gallons]),3),
			    FILTER(
			        'D_Calendar',
			        'D_Calendar'[CALENDAR_DATE] >= StartOfThreeMonthsAgo &&
			        'D_Calendar'[CALENDAR_DATE] <= EndOfLastMonth
			    )
			)
		formatString: #,0
		displayFolder: Gal
		lineageTag: ae20612c-fc1e-48cc-888e-55b68dfe3dee

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'CM Amount(PPG)' =
			
			VAR LatestMonth = MAX('F_Fleet_Expenses'[Date])
			RETURN
			CALCULATE(
			    ([Price/Gall]),
			    FILTER(
			        'D_Calendar',
			        MONTH('D_Calendar'[CALENDAR_DATE]) = MONTH(LatestMonth) &&
			        YEAR(D_Calendar[CALENDAR_DATE]) = YEAR(LatestMonth)
			    )
			)
		formatString: #,0.00
		displayFolder: PPG
		lineageTag: 19965d1a-e079-4fb7-a2fc-d27847268845

	measure 'Prior 3MA(PPG)' =
			
			VAR LatestDate = MAX('F_Fleet_Expenses'[Date])
			VAR EndOfLastMonth = EOMONTH(LatestDate, -3)
			VAR StartOfThreeMonthsAgo = EOMONTH(LatestDate, -6) + 1
			RETURN
			CALCULATE(
			    DIVIDE(Sum(F_Fleet_Expenses[FuelAmount]),Sum(F_Fleet_Expenses[Gallons])),
			    FILTER(
			        'D_Calendar',
			        'D_Calendar'[CALENDAR_DATE] >= StartOfThreeMonthsAgo &&
			        'D_Calendar'[CALENDAR_DATE] <= EndOfLastMonth
			    )
			)
		formatString: #,0.00
		displayFolder: PPG
		lineageTag: 10e811f0-2094-4c3a-ac55-607c84bb07a1

	measure '%Change.CM' = [$Change.CM]/[CM Amount]
		formatString: 0.00%;-0.00%;0.00%
