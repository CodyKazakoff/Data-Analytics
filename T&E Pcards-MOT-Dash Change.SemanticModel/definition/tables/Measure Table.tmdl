			)
		formatString: #,0
		displayFolder: CMFuel
		lineageTag: 0361376d-8c9e-4572-9936-0c84e56c2327

		annotation PBI_FormatHint = {"isDecimal":true}

	measure CM3MA = ```
			
			SWITCH(
			    TRUE(),
			    [%Change.3MA] > 0.2, "#cf7673",  // Red for positive values
			    [%Change.3MA] < -0.2, "#8bd7b3"  // Green for negative values
			     //no color
			   
			)
			```
		displayFolder: 3MA
		lineageTag: 23bbb43e-8a49-4471-b948-296e94fb163e

