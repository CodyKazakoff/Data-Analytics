	partition z_Param_Customer_Summary = calculated
		mode: import
		source =
				{
				
				//All Customer Summary
				    ("Branch", NAMEOF(D_Location[MI Loc]), 0, 0),
				    ("Br/Cust No", NAMEOF('D_Customer_ShipTo'[MI Loc  Ship To Customer No  Ship To Customer Name]), 1, 0),
				    ("Customer Name", NAMEOF('D_Customer_ShipTo'[Ship To Customer Name]), 2, 0),
				    ("Territory", NAMEOF('D_Customer_ShipTo'[Territory Full Name]), 3, 0),
				    ("Order Amount", NAMEOF('Measure Table'[Total $]), 4, 0),
				    ("GP %", NAMEOF('Measure Table'[Order GP %]), 5, 0),
				    ("Open Order Amount", NAMEOF('Measure Table'[Total $]), 6, 0),
				    ("CY Order Amount", NAMEOF('Measure Table'[Total $ CYTD]), 7, 0),
				    ("CY GP %", NAMEOF('Measure Table'[Order GP %]), 8, 0),
				    ("PY Order Amount", NAMEOF('Measure Table'[Total $ PYTD]), 9, 0),
				    ("PY GP %", NAMEOF('Measure Table'[Order GP %]), 10, 0),
				    ("Total # Orders", NAMEOF('Measure Table'[Order #]), 11, 0),
				
				//New Customer Summary
				    ("Br/Cust No", NAMEOF('D_Customer_ShipTo'[MI Loc  Ship To Customer No  Ship To Customer Name]), 12, 1),
				    ("Customer Name", NAMEOF('D_Customer_ShipTo'[Ship To Customer Name]), 13, 1),
				    ("Territory", NAMEOF('D_Customer_ShipTo'[Territory Full Name]), 14, 1),
				    ("Order Amount", NAMEOF('Measure Table'[Total $]), 15, 1),
				    ("Account Creation Date", NAMEOF('D_Customer_BillTo'[Creation Date]), 16, 1),
				    ("Pick 12 Acct", NAMEOF('Measure Table'[Blank Measure]), 17, 1)
				
				
				
				}

