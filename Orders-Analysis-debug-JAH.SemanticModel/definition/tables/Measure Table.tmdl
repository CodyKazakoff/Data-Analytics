	measure 'Filters Applied' =
			
			VAR MaxFilters = 3
			RETURN
			IF(
			    ISFILTERED(D_Calendar_Filter[Year]),
			    VAR ___f = FILTERS(D_Calendar_Filter[Year])
			    VAR ___d = CONCATENATEX(___f,D_Calendar_Filter[Year],", ")
			    VAR ___x = "𝗬𝗲𝗮𝗿: " & ___d & " "
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			& IF(
			    ISFILTERED(D_Calendar_Filter[Quarter]),
			    VAR ___f = FILTERS(D_Calendar_Filter[Quarter])
