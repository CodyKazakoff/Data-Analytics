	measure 'RowCount Hide Condition' = COUNTROWS('F_Order_Item')
		formatString: #,0
		displayFolder: Metadata
		lineageTag: 1a36ef78-71d5-4238-a05e-9e418af0c64c

		changedProperty = IsHidden

	measure 'Show Condition' =
			
			//Determines what is selected from the parameter
			VAR vSelectedValue = SELECTEDVALUE ( 'z_Param_Calc_Condition_Details'[Show/Hide])
			
			//The number of rows available with current selections
			VAR vRowCount =
			CALCULATE(
			    [RowCount Hide Condition]
			    , ALLSELECTED()
			)
			
			//Returns Show if < 100 rows and Hide if > 100 rows
			VAR vResult = (vRowCount < 150000 && vSelectedValue = "Show") || (vRowCount >= 150000 && vSelectedValue = "Hide")
			
			RETURN vResult
		formatString: """TRUE"";""TRUE"";""FALSE"""
		displayFolder: Metadata
		lineageTag: a80cb080-c166-4cd2-820f-85a874322c4f

		changedProperty = IsHidden

	measure 'zSelected Time Frame' = ```
			
			
			VAR vCY = 
			CALCULATE(
			MAX('D_Calendar_Filter'[Month Index])
			,ALLSELECTED('D_Calendar_Filter')
			)
			
			VAR vCM =
			CALCULATE(
			MAX('D_Calendar_Filter'[Month Number])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[Month Index] = vCY
			))
			
			VAR vCDayOfMonth =
			CALCULATE(
			"MTD:" & MIN('D_Calendar_Filter'[Calendar Date]) & " - " & MAX('D_Calendar_Filter'[Calendar Date])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[Month Number] = vCM
			)
			)
			
			Return vCDayOfMonth
			```
		displayFolder: Metadata
		lineageTag: 1d76f7c9-08d0-4b3d-be91-4b30626b9416

		changedProperty = IsHidden

	measure 'zSelected Time Frame - Previous' = ```
			
			
