	measure 'Bar Chart Color Comparisons' =
			
			Var MeasureIndex = SelectedValue('z_Bar_Chart_Measures_Slicer'[Measure Index])
			Var KPISlicer = SELECTEDVALUE('z_KPI_Slicer'[Index])
			Var Red = "#FF1010"
			Var Green = "#72FFB7"
			Var ColorSwitch = Switch(TRUE(),
			
			    KPISlicer = 0  && [Total $ CYTD] < [Total $ PYTD], Red,
			    KPISlicer  = 0  && [Total $ CYTD] > [Total $ PYTD], Green,
			    KPISlicer = 1  && [Total $ CMTD] > [Total $ PMTD], Green,
			    KPISlicer = 1  && [Total $ CMTD] < [Total $ PMTD], Red,
			    KPISlicer = 2  && [Total $ CQTD] < [Total $ PQTD], Red,
			    KPISlicer = 2  && [Total $ CQTD] > [Total $ PQTD], Green
			
			)
			/*
			 KPISlicer = 0 && MeasureIndex = 1 && [Order Amount YTD] < [Order Amount PYTD], Red,
			    KPISlicer  = 0 && MeasureIndex = 1 && [Order Amount YTD] > [Order Amount PYTD], Green,
			    KPISlicer = 1 && MeasureIndex = 1 && [Order Amount MTD] > [Order Amount PMTD], Green,
			    KPISlicer = 1 && MeasureIndex = 1 && [Order Amount MTD] < [Order Amount PMTD], Red,
			    KPISlicer = 2 && MeasureIndex = 1 && [Order Amount CQTD] < [Order Amount PQTD], Red,
			    KPISlicer = 2 && MeasureIndex = 1 && [Order Amount CQTD] > [Order Amount PQTD], Green,
			
			    KPISlicer = 0 && MeasureIndex = 2 && [ADO YTD] < [ADO PYTD], Red,
			    KPISlicer = 0 && MeasureIndex = 2 && [ADO YTD] > [ADO PYTD], Green,
			    KPISlicer = 1 && MeasureIndex = 2 && [ADO MTD] > [ADO PMTD], Green,
			    KPISlicer = 1 && MeasureIndex = 2 && [ADO MTD] < [ADO PMTD], Red,
			    KPISlicer = 2 && MeasureIndex = 2 && [ADO CQTD] < [ADO PQTD], Red,
			    KPISlicer = 2 && MeasureIndex = 2 && [ADO CQTD] > [ADO PQTD], Green
			*/
			Return ColorSwitch
		displayFolder: Metadata
		lineageTag: 0b547d62-0245-4752-8600-a75c691db379

		changedProperty = IsHidden

