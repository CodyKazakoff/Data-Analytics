/// Sum of total Reportable Accidents
table 'Measure Table'
	lineageTag: ce2aa14d-6693-4b71-be30-f49cd138f021

	/// Refresh Date for Loss Run Report
	measure 'Report Refresh Date' = "Report as of: " & Max('zLast Refresh Datetime'[Last Refresh Datetime])
		displayFolder: Metadata
		lineageTag: 2360455c-966c-4ea4-af74-a5137572a971

		changedProperty = IsHidden

	measure 'Total $' = ```
			VAR vSelectedValue = SELECTEDVALUE('z_Currency_Slicer'[Key])
			
			 VAR vResult =
			 Switch( True, 
			 vSelectedValue = 1 , sum(F_Order_Item[Itm Unit Sell Amt USD]), 
			 vSelectedValue = 2, sum(F_Order_Item[Itm Unit Sell Amt Local]), 
			 sum(F_Order_Item[Itm Unit Sell Amt USD]))
			 
			 RETURN
			 vResult
			```
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Total $
		lineageTag: 24cdceb1-e8e8-44e5-8d17-6aedaa05b79c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Order GP %' = DIVIDE ([Order Gross Profit] ,[Order $])
		formatString: #,0.0%;-#,0.0%;#,0.0%
		displayFolder: Order Gross Profit %
		lineageTag: 6fa4b0c3-530d-44e3-80c1-77412c303185

		changedProperty = IsHidden

	measure 'Average Order $' = DIVIDE([Order $],  [Order #])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Average Order $
		lineageTag: e21f812a-7366-4ae1-8a7d-ea7bf67d3966

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Order #' =
			CALCULATE(
			    [Total #],
			     F_Order_Item[Order Type Desc] = "Order"
			)
		formatString: #,0
		displayFolder: Order #
		lineageTag: 28c9fa81-a6e1-4667-89c6-2947f244ad57

		changedProperty = IsHidden

	measure 'Average Daily Order $' = DIVIDE([Order $], [Workday of Year])
