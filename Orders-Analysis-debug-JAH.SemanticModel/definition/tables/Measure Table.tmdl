	measure 'PYTD Display' = "PY: " & Max(D_Calendar_Filter[YEAR])-1
		displayFolder: Time Period Metadata
		lineageTag: 342382d7-1ba1-44be-8496-593ad0ec1b56

		changedProperty = IsHidden

	measure 'Prior 24 Start' = ```
			
			
			VAR vCYEnd = Calculate(FIRSTNONBLANK(D_Calendar_Filter[Month Year],1), Filter(D_Calendar_Filter, D_Calendar_Filter[Month Index] =Max(D_Calendar_Filter[Month Index])-13) )
			VAR vCYStart = Calculate(FIRSTNONBLANK(D_Calendar_Filter[Month Year],1), Filter(D_Calendar_Filter, D_Calendar_Filter[Month Index] =Max(D_Calendar_Filter[Month Index])-24) ) 
			RETURN "P12M: " & vCYStart & " - " & vCYEnd
			```
		displayFolder: Time Period Metadata
		lineageTag: 226b0a92-3cd4-4277-8976-4236817d4083

		changedProperty = IsHidden

	measure 'PQTD Display' = ```
			
			VAR vCQ =
			    CALCULATE (
			        MAX ( 'D_Calendar_Filter'[Quarter Index] ),
			        ALLSELECTED ( 'D_Calendar_Filter' )
			    )
			
			    
			VAR vResult =
			    CALCULATE (
			        MAX(D_Calendar_Filter[Year Quarter]),
			        FILTER (
			            ALL ( 'D_Calendar_Filter'),
			            'D_Calendar_Filter'[Quarter Index] = ( vCQ - 4 )
			
			        )
			    ) 
			RETURN "PQ: " & vResult
			```
		formatString: 0
		displayFolder: Time Period Metadata
		lineageTag: f815e40f-0db8-417b-af53-7d97051c879d

		changedProperty = IsHidden

	measure 'PMTD Display' = ```
			
			
			VAR vCM =
			    CALCULATE (
			        MAX ( 'D_Calendar_Filter'[Month Index] ),
			        ALLSELECTED ( 'D_Calendar_Filter' )
			    )
			VAR vCDayOfMonth =
			    CALCULATE (
			        MAX('D_Calendar_Filter'[Workday Of Month]),
			        FILTER ( ALLSELECTED ( 'D_Calendar_Filter' ), 'D_Calendar_Filter'[Month Index] = vCM )
			    )
			VAR vResult =
			    CALCULATE (
			        MAX(D_Calendar_Filter[Month Year]),
			        FILTER (
			            ALL ( 'D_Calendar_Filter' ),
			            'D_Calendar_Filter'[Month Index] =  vCM - 12 && 
			            'D_Calendar_Filter'[Workday Of Month] <= vCDayOfMonth
			        )
			    )
			RETURN
			   "PM: " & vResult
			```
		displayFolder: Time Period Metadata
		lineageTag: d03ab6d3-a6c9-4370-8332-803dc2f4bac9

		changedProperty = IsHidden

	measure 'Max Month Year' = ```
			
			VAR vCYEnd = Calculate(FIRSTNONBLANK(D_Calendar_Filter[Month Year],1), Filter(D_Calendar_Filter, D_Calendar_Filter[Month Index] =Max(D_Calendar_Filter[Month Index])-1) )
			VAR vCYStart = Calculate(FIRSTNONBLANK(D_Calendar_Filter[Month Year],1), Filter(D_Calendar_Filter, D_Calendar_Filter[Month Index] =Max(D_Calendar_Filter[Month Index])-12) ) 
			RETURN "12M: " & vCYStart & " - " & vCYEnd
			```
		displayFolder: Time Period Metadata
		lineageTag: ad3bcda8-4369-424c-bbf2-5bbe22df7d04

		changedProperty = IsHidden

	measure 'CYTD Display' = ```
			
			VAR vYear = Max(D_Calendar_Filter[Year])
			RETURN
			"CY: " & vYear 
			```
		displayFolder: Time Period Metadata
		lineageTag: bbd03706-66d8-475c-b541-c5f828234cbd

		changedProperty = IsHidden

