	measure 'Max Date' =
			
			VAR maxsalesdate = CALCULATE(max(F_Order_Item[Converted To Order Date]),REMOVEFILTERS(F_Order_Item))
			
			RETURN
			CALCULATE(max(D_Calendar_Filter[Calendar Date]),Filter(D_Calendar_Filter,D_Calendar_Filter[Calendar Date]<=maxsalesdate))
