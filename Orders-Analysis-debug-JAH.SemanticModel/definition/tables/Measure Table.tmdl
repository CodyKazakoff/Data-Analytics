	measure 'CMTD Period' = ```
			
			
			VAR vCY = 
			CALCULATE(
			MAX('D_Calendar_Filter'[YEAR])
			,ALLSELECTED('D_Calendar_Filter')
			)
			
			VAR vCM =
			CALCULATE(
			MAX('D_Calendar_Filter'[Month Number])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[YEAR] = vCY
			))
			
			VAR vCDayOfMonth =
			CALCULATE(
			MAX('D_Calendar_Filter'[Day Of Month])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[Month Number] = vCM
			)
			)
			
			VAR vMinDate =
			 Calculate(Min('D_Calendar_Filter'[Calendar Date])
			, 'D_Calendar_Filter'[Month Number] = vCM
			&& 'D_Calendar_Filter'[Day Of Month] <= vCDayOfMonth
			&& 'D_Calendar_Filter'[Year] = vCY)
			
			VAR vMaxDate =
			 Calculate(Max('D_Calendar_Filter'[Calendar Date])
			, 'D_Calendar_Filter'[Month Number] = vCM
			&& 'D_Calendar_Filter'[Day Of Month] <= vCDayOfMonth
			&& 'D_Calendar_Filter'[Year] = vCY)
			
			Var vResult = 
			"CMTD: " & vMinDate & " - " & vMaxDate
			
			RETURN vResult
			```
		displayFolder: Metadata
		lineageTag: f4247d80-6603-4fa1-851a-3f627668f92a

		changedProperty = IsHidden

	measure 'PMTD Period' = ```
			
			
			VAR vCY = 
			CALCULATE(
			MAX('D_Calendar_Filter'[Year])
			,ALLSELECTED('D_Calendar_Filter')
			)
			
			VAR vPM =
			CALCULATE(
			MAX('D_Calendar_Filter'[Month Number])-1
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[YEAR] = vCY
			))
			
			VAR vCM =
			CALCULATE(
			MAX('D_Calendar_Filter'[Month Number])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[YEAR] = vCY
			))
			
			VAR vCDayOfMonth =
			CALCULATE(
			MAX('D_Calendar_Filter'[Day Of Month])
			, FILTER(ALLSELECTED('D_Calendar_Filter')
			, 'D_Calendar_Filter'[Month Number] = vCM
			)
			)
			
			VAR vMinDate =
			 Calculate(Min('D_Calendar_Filter'[Calendar Date])
			, 'D_Calendar_Filter'[Month Number] = vPM
			&& 'D_Calendar_Filter'[Day Of Month] <= vCDayOfMonth
			&& 'D_Calendar_Filter'[Year] = vCY)
			
			VAR vMaxDate =
			 Calculate(Max('D_Calendar_Filter'[Calendar Date])
			, 'D_Calendar_Filter'[Month Number] = vPM
			&& 'D_Calendar_Filter'[Day Of Month] <= vCDayOfMonth
			&& 'D_Calendar_Filter'[Year] = vCY)
			
			Var vResult = 
			"PMTD: " & vMinDate & " - " & vMaxDate
			
			RETURN vResult
			```
		displayFolder: Metadata
		lineageTag: 0bd3c7c5-c13b-4f55-88c5-2aca3f4b9b5b

		changedProperty = IsHidden

