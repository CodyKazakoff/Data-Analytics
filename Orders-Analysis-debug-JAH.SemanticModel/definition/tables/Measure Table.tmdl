		lineageTag: a5d18a36-4e1d-4d1d-818c-4fb4298c99a3

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Average Lines per Order' = ```
			
			Divide(
