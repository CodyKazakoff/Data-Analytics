	column 'Due Date Bucket' =
			
			IF(F_Order_Item[Itm Promised Delivery Date]=DATE(1900, 1, 1),"Due Date Missing",
			IF(F_Order_Item[Late Line Days]<-30,"Due 30+ Days",
			IF(F_Order_Item[Late Line Days]<-7,"Due in 7-30 Days",
			IF(F_Order_Item[Late Line Days]<=0,"Due in <7 Days",
			IF(F_Order_Item[Late Line Days]<=7,"<7 Days Late",
			IF(F_Order_Item[Late Line Days]<=30,"7-30 Days Late",
			IF(F_Order_Item[Late Line Days]<=60,"30-60 Days Late",
			IF(F_Order_Item[Late Line Days]<=90,"60-90 Days Late",
			"90+ Days Late"
			))))))))
		lineageTag: aaa6a7cd-cdc1-4337-99d2-501bcb6a6766
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Parent Source' =
			
			IF(F_Order_Item[Order Source Desc]="ACCOUNT REP", "Account Rep",
			IF(F_Order_Item[Order Source Desc]="AFTER HOURS (NIGHT CALL)","Phone",
			IF(F_Order_Item[Order Source Desc]="ASSIGNED ORDER", "Other",
			IF(F_Order_Item[Order Source Desc]="COUNTER","Other",
			IF(F_Order_Item[Order Source Desc]="CUSTOMER PORTAL", "Customer Portal",
			IF(F_Order_Item[Order Source Desc]="EDI","Customer Portal",
			IF(F_Order_Item[Order Source Desc]="E-MAIL ORDER", "Email",
			IF(F_Order_Item[Order Source Desc]="REPLENISHMENT", "Other",
			IF(F_Order_Item[Order Source Desc]="SMART EMAIL", "Email",
			IF(F_Order_Item[Order Source Desc]="SMART EMAIL 2.0", "Email",
			IF(F_Order_Item[Order Source Desc]="SOLICITED BY VISIT", "Account Rep",
			IF(F_Order_Item[Order Source Desc]="STOREROOM ORDER", "Other",
			IF(F_Order_Item[Order Source Desc]="TELEPHONE", "Phone",
			IF(F_Order_Item[Order Source Desc]="WEB ENTER ORDER", "Web",
			IF(F_Order_Item[Order Source Desc]="ACQUISITION CONVERSION", "Other",
			IF(F_Order_Item[Order Source Desc]="AUTOMATED EMAIL", "Email",
			IF(F_Order_Item[Order Source Desc]="WEB ENTER ORDER", "Web",
			IF(F_Order_Item[Order Source Desc]="BRANCH TRANSFER", "Other",
			IF(F_Order_Item[Order Source Desc]="CONSIGNMENT REPLENISHMENT", "Other",
			IF(F_Order_Item[Order Source Desc]="CUSTOMER DROP OFF", "Other",
			IF(F_Order_Item[Order Source Desc]="DC COUNTER SALES", "Other",
			IF(F_Order_Item[Order Source Desc]="ELECTRONIC ORDER EXPECTED", "Web",
			IF(F_Order_Item[Order Source Desc]="EXCHANGE ORDERS", "Other",
			IF(F_Order_Item[Order Source Desc]="FAX", "Email",
			IF(F_Order_Item[Order Source Desc]="MAIL", "Email",
			IF(F_Order_Item[Order Source Desc]="MI PRO SALES", "Web",
			IF(F_Order_Item[Order Source Desc]="PUNCHOUT", "Other",
			IF(F_Order_Item[Order Source Desc]="SECOND TIER ORDER", "Other",
			IF(F_Order_Item[Order Source Desc]="SOLICITED BY PHONE", "Phone",
			IF(F_Order_Item[Order Source Desc]="TEXT MESSAGE", "Phone",
			IF(F_Order_Item[Order Source Desc]="VENDING", "Other",
			IF(F_Order_Item[Order Source Desc]="WEB LEAD", "Web",
			BLANK()))))))))))))))))))))))))))))))))
		lineageTag: 6ba1acfd-8e9c-4c16-94a3-79a823a5943f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

