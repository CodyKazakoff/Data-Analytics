	column 'Late Line Days' = DATEDIFF(F_Order_Item[Itm Promised Delivery Date],TODAY()-1,DAY)
		formatString: 0
		lineageTag: 7f7e03bb-66e4-46da-9776-3cac7be477fe
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Days Past Delivery' = DATEDIFF(F_Order_Item[Itm Promised Delivery Date],TODAY()-1,DAY)
		formatString: 0
		lineageTag: 3cc92079-4a39-4aac-9615-53c2cb0f08c0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Past Due Bucket' =
			
			IF(F_Order_Item[Days Past Delivery]<0,"On-Time",
			IF(F_Order_Item[Days Past Delivery]<31,"0-30",
			IF(F_Order_Item[Days Past Delivery]<61,"31-60",
			IF(F_Order_Item[Days Past Delivery]<91,"61-90",
			IF(F_Order_Item[Days Past Delivery]<121,"91-120","121+")))))
		lineageTag: 787b3bd7-4a9f-416e-92a6-c257af261c02
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

