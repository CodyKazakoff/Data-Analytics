	column 'Order Writer' =
			
			VAR PipePosition = FIND("|", F_Order_Item[Entered By Name], 1, 0)
			RETURN
			    IF(
			        PipePosition > 0,
			        TRIM(RIGHT(F_Order_Item[Entered By Name], LEN(F_Order_Item[Entered By Name]) - PipePosition)),
			        BLANK()
			    )
		lineageTag: ed9c0c68-ebff-4753-82c2-551a89a5b49f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

