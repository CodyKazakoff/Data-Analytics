		calculationItem PY = ```
				
				VAR vCY =
				
				CALCULATE(
				
				MAX('D_Calendar_Filter'[Year]), 
				ALLSELECTED('D_Calendar_Filter')
				
				)
				
				
				
				VAR vResult =
				
				CALCULATE(
				
				SELECTEDMEASURE(), 
				FILTER(ALL('D_Calendar_Filter'), 
				'D_Calendar_Filter'[Year] = vCY - 1
				
				)
				
				)
				
				
				RETURN vResult
				```

		calculationItem 12_Month_Rolling_CM = ```
				
				VAR MaxDate = MAX ( D_Calendar_Filter[Calendar Date])
				VAR MinDate = EOMONTH(MaxDate,-13)+1
				 
				VAR vResult =
				CALCULATE (
				    SELECTEDMEASURE(),
				    KEEPFILTERS( D_Calendar_Filter[Calendar Date] >= MinDate ),
				    KEEPFILTERS( D_Calendar_Filter[Calendar Date] <  MaxDate )
				)
				RETURN vResult
				```

