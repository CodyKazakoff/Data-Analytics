	partition z_Param_Quotes_Open_Orders = calculated
		mode: import
		source = ```
				{
				    //At Risk Customer List
				    ("Customer Name", NAMEOF('D_Customer_ShipTo'[MI Loc  Ship To Customer No  Ship To Customer Name]), 0,"At Risk Customer List"),
				    ("Acct Rep", NAMEOF(D_Customer_ShipTo[Territory Full Name]), 0,"At Risk Customer List"),
				    ("Order $ Rolling 12", NAMEOF('Measure Table'[Total $ Rolling 12M]), 1,"At Risk Customer List"),
				    ("Open Quote #", NAMEOF('Measure Table'[Open Quote #]), 2,"At Risk Customer List"),
				    ("Last Quote Date", NAMEOF('D_Customer_ShipTo'[Ship To Cust Last Quote Date]), 3,"At Risk Customer List"),
				    ("Days Since Last Quote", NAMEOF('D_Customer_ShipTo'[Ship To Cust Days Since Quote]), 4,"At Risk Customer List"),
				    ("Last Order Date", NAMEOF('D_Customer_ShipTo'[Ship To Cust Last Order Date]), 5,"At Risk Customer List"),
				    ("Days Since Last Order", NAMEOF('D_Customer_ShipTo'[Ship To Cust Days Since Order]), 6,"At Risk Customer List"),
				    ("Open Order Count#", NAMEOF('Measure Table'[Open Order #]), 7,"At Risk Customer List"),
				
				    
				    //Open Quotes
				    ("Customer Name", NAMEOF('D_Customer_ShipTo'[MI Loc  Ship To Customer No  Ship To Customer Name]), 7,"Open Quotes"),
				    ("Territory", NAMEOF('D_Customer_ShipTo'[Territory Employee Name]), 8,"Open Quotes"),
				    ("OCN", NAMEOF(F_Order_Item[Order Ctl No]), 9,"Open Quotes"),
				    ("Total Lines Quoted", NAMEOF([Open Quote Line #]), 10,"Open Quotes"),
				    ("Order Creation Date", NAMEOF(F_Order_Item[Order Date]), 11,"Open Quotes"),
				    ("Open Quote $", NAMEOF([Open Quote $]), 12,"Open Quotes"),
				
				    //Open Orders
				    ("Customer Name", NAMEOF('D_Customer_ShipTo'[MI Loc  Ship To Customer No  Ship To Customer Name]), 13,"Open Orders"),
				    ("Territory", NAMEOF('D_Customer_ShipTo'[Territory Employee Name]), 14,"Open Orders"),
				    ("OCN", NAMEOF(F_Order_Item[Order Ctl No]), 15,"Open Orders"),
				    ("Total Lines Ordered", NAMEOF([Open Order Line #]), 16,"Open Orders"),
				    ("Converted to Order Date", NAMEOF(F_Order_Item[Converted To Order Date]), 17,"Open Orders"),
				    ("Due Date", NAMEOF(F_Order_Item[Due Date]), 18,"Open Orders"),
				    ("Open Order $", NAMEOF([Open Order $]), 19,"Open Orders")
				}
				```

