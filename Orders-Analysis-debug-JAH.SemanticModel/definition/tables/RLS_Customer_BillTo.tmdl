	partition RLS_Customer_BillTo = m
		mode: import
		queryGroup: Security
		source =
				let
				    Source = Sql.Database(Lakehouse&".datawarehouse.fabric.microsoft.com", "Enterprise_Analytics"),
				    dbo_RLS_Customer_BillTo = Value.NativeQuery(Source,
				    "SELECT DIM.* FROM V_RLS_Customer_BillTo DIM
				        INNER JOIN (SELECT DISTINCT BILL_TO_CUST_KEY FROM dbo.F_Shipper_Item
				    WHERE ORIGINAL_SOURCE_SYSTEM <> 'Intercompany Transfers') FAC
				        ON FAC.BILL_TO_CUST_KEY = DIM.BILLING_CUST_KEY", null, [EnableFolding = false])
				in
				    dbo_RLS_Customer_BillTo

	annotation PBI_NavigationStepName = Navigation

