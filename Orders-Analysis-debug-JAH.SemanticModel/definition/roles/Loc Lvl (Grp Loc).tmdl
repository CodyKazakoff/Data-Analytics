role 'Loc Lvl (Grp Loc)'
	modelPermission: read

	tablePermission D_Location = ```
			VAR vAccessList = SELECTCOLUMNS(    
			    FILTER('RLS_HR_Hierarchy',
			        RLS_HR_Hierarchy[EMPLOYEE_UPN]=USERPRINCIPALNAME()),
			        "Security list", RLS_HR_Hierarchy[EMPLOYEE_MI_GROUP_LOC])
			         
			VAR vAccess = D_Location[MI Group Loc] in vAccessList 
			
			Return vAccess
			```

	tablePermission RLS_HR_Hierarchy = 'RLS_HR_Hierarchy'[EMPLOYEE_UPN] = USERPRINCIPALNAME()

	annotation PBI_Id = e9a5adb85cb748aa985171a5314c22b3

