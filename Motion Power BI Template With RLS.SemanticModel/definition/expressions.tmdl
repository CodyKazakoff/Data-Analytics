expression fx_Loop = ```
		let
		    fx = (
		            p_startIteration as number
		            , p_endIteration as number
		            , p_increment as number
		            //Function to be called on each iteration. This function should be expecting a numeric iteration paramter
		            , p_function as function
		            , optional p_combineresultsets as logical
		            , optional p_result as table
		            , optional p_currentIteration as number) =>
		    let
		        currentIteration =              if p_currentIteration = null
		                                            then p_startIteration
		                                            else p_currentIteration,
		        //Run function that gets table for current iterations min/max dates
		        currentResultSet =              @p_function(currentIteration, p_result),
		        //Combine current table with prior iterations (if there are prior iterations)
		        fullResultTable =               if p_result = null or p_combineresultsets = false
		                                                then currentResultSet
		                                                else Table.Combine({p_result, currentResultSet}),
		        //Increment loop
		        nextIteration = currentIteration + p_increment,
		        //If there are still iterations to run, call this function again and pass the next iteration and the current table to append to
		        //Otherwise, return the current output.
		        Output = 
		        if nextIteration <= p_endIteration
		            then @fx_Loop(p_startIteration, p_endIteration, p_increment, p_function, p_combineresultsets, fullResultTable, nextIteration)
		            else fullResultTable
		    in
		    Output
		    , fx_Type = type function
		    (
		        p_startIteration as number
		        , p_endIteration as number
		        , p_increment as number
		        //Function to be called on each iteration. This function should be expecting a numeric iteration paramter
		        , p_function as function
		        , optional p_combineresultsets as logical
		        , optional p_result as table
		        , optional p_currentIteration as number
		    ) as any meta
		    [
		        Documentation.Name = "fx_Loop"
		        , Documentation.Description = "This function provides a facility to iterate over a list of values and exucute a user defined function in each iteration. When invoking this function, you should never need to define p_result or p_currentIteration, those are defined as part of the fx_Loop itself."
		        , Documentation.Examples = 
		        {
		            [
		                Description = "Iterate from 0 to 9 by 1 and add each number to a table. Return a table with values 0 to 9."
		                , Code = 
		"fx_Loop(
		    0
		    , 9
		    , 1
		    , (p_iteration as number, optional p_result as table) => let
		        //Logic that uses current iteration
		        loopOutput          = #table({""Column""}, {{p_iteration}})
		    in
		        //Output that will be used as result.
		        loopOutput
		)"
		                , Result = 
		"{
		    [Column = 0]
		    , [Column = 1]
		    , [Column = 2]
		    , [Column = 3]
		    , [Column = 4]
		    , [Column = 5]
		    , [Column = 6]
		    , [Column = 7]
		    , [Column = 8]
		    , [Column = 9]
		}"
		            ]
		            , [
		                Description = "Iterate from 0 to 9 by 1 and add each number to a table. Return with only the last result."
		                , Code = 
		"fx_Loop(
		    0
		    , 9
		    , 1
		    , (p_iteration as number, optional p_result as table) => let
		        //Logic that uses current iteration
		        loopOutput          = #table({""Column""}, {{p_iteration}})
		    in
		        //Output that will be used as result.
		        loopOutput
		    , false
		)"
		                , Result = 
		"{
		    [Column = 0]
		    , [Column = 1]
		    , [Column = 2]
		    , [Column = 3]
		    , [Column = 4]
		    , [Column = 5]
		    , [Column = 6]
		    , [Column = 7]
		    , [Column = 8]
		    , [Column = 9]
		}"
		            ]
		        }
		    ]
		    
		in
		Value.ReplaceType(fx, fx_Type)
		```
	lineageTag: 82f4a47e-7d67-449a-a44e-1f169ae0ccf1
	queryGroup: Functions

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression fx_TableProfile = ```
		let
		    //This is a comment
		    fx = (p_SourceTable as table, optional p_ColumnName as text, optional p_TableName as text) => let
		        filteredSouceTable              = if p_ColumnName <> null
		                                            then Table.SelectColumns(p_SourceTable,{p_ColumnName})
		                                            else p_SourceTable,
		
		        //Get the base profile table for the table we want to profile
		        tempProfile                     = Table.Profile(
		                                            filteredSouceTable,
		                                            {
		                                                {"Median", each Type.Is(_, type number), List.Median}
		                                                , {"Mode", each Type.Is(_, type number), List.Mode}
		                                            }
		                                        ),
		        tempProfileRemovedColumns       = Table.RemoveColumns(tempProfile,
		                                            {
		                                                "DistinctCount"
		                                            }),
		        tempProfileRenamedColumns       = Table.RenameColumns(tempProfileRemovedColumns,
		                                            {
		                                                {"Count", "Row Count"}
		                                            }),
		        //Add an index column that we can use to loop over rows.
		        Profile                         = Table.AddIndexColumn(tempProfileRenamedColumns, "Column Index", 0, 1, Int64.Type),
		
		        //Add % of values in column that are null & flag columns that are 100% null
		        #"% Null"                       = Table.AddColumn(Profile, "% Null", each [NullCount] / [Row Count], Percentage.Type),
		        #"Flag.Contains Nulls"              = Table.AddColumn(#"% Null", "Flag.Contains Nulls", each if [NullCount] > 0 then true else false, type logical),
		   
		        //Start loop function
		        LoopOutput = fx_Loop(
		            //Loop params
		            //Loop Start
		            0
		            //Loop End
		            , (Table.RowCount(Profile) - 1)
		            //Loop Increment
		            , 1
		            //Create function that will be looped over
		            , (p_iteration as number, optional p_result as table) => let
		
		                //Get the row that we're interested in, based on the iteration
		                fieldRow                = Table.SelectRows(#"Flag.Contains Nulls", each [Column Index] = p_iteration),
		
		                //Get column name for use in later steps
		                columnName              = fieldRow{0}[Column],
		                
		                //Get a list of all the values for a field so we can interrogate it.
		                fieldValues         = Table.Column(filteredSouceTable, columnName),
		    
		                //Add % of values in column that are Distinct
		                //Recalculating Distinct count because the default method that comes out of Table.Profile throws an error if there are nulls in the column
		                DistinctValues          = List.Count(List.Distinct(fieldValues)),
		                AddDistinctValues       = Table.AddColumn(fieldRow, "Distinct Values", each DistinctValues, type number),
		                #"% Distinct"           = Table.AddColumn(AddDistinctValues, "% Distinct", each [Distinct Values] / [Row Count], Percentage.Type),
		                #"Flag.100% Distinct"   = Table.AddColumn(#"% Distinct", "Flag.100% Distinct", each if [#"% Distinct"] = 1 then true else false, type logical),
		
		                BlankCount              = List.Count(List.Select(fieldValues, each Text.Trim(Text.From(_)) = "")),
		                AddBlankCount           = Table.AddColumn(#"Flag.100% Distinct", "BlankCount", each BlankCount, type number),
		                
		                //Add % of values in column that are Blank
		                #"% Blank"              = Table.AddColumn(AddBlankCount, "% Blank", each [BlankCount] / [Row Count], Percentage.Type),
		                #"Flag.Contains Blanks" = Table.AddColumn(#"% Blank", "Flag.Contains Blanks", each if [BlankCount] > 0 then true else false, type logical),
		
		                BlankError              = if BlankCount > 0 then Text.Combine({columnName, " Contains Blanks"}) else null,
		                NullError               = if fieldRow{0}[NullCount] > 0 then Text.Combine({columnName, " Contains Nulls"}) else null,
		
		                Errors                  = if
		                                            BlankError <> null
		                                            or NullError <> null
		                                            //or TestError <> null
		                                            then 
		                                                error Error.Record(Text.Combine({"Errors were found in ", columnName})
		                                                , "Check this column for errors"
		                                                , Text.Combine(
		                                                    {
		                                                        "#(tab)"
		                                                        , if BlankError <> null then Text.Combine({BlankError, "#(cr,tab)"}) else null
		                                                        , if NullError <> null then Text.Combine({NullError, "#(cr,tab)"}) else null
		                                                    })
		                                                )
		                                            else null,
		
		                AddErrorColumn          = Table.AddColumn(#"Flag.Contains Blanks", "Errors", each Errors, type logical),
		
		                //Add table name. This is useful when we're profiling the whole dataset, rather than just an individual table.
		                TableName               = if p_TableName = null
		                                            then "Table"
		                                            else p_TableName,
		                
		                //Add table name column, and send output to next iteration
		                loopOutput              = Table.AddColumn(AddErrorColumn, "Table Name", each TableName, type text)
		            in
		                //Output that will be used as result.
		                loopOutput),
		        LoopOutputRemoveColumns         = Table.RemoveColumns(LoopOutput,
		                                            {
		                                                "Column Index"
		                                            }),
		        
		        #"Reorder Columns"              = Table.ReorderColumns(LoopOutputRemoveColumns,
		            {
		                "Column"
		                , "Errors"
		                , "Flag.100% Distinct"
		                , "Flag.Contains Nulls"
		                , "Flag.Contains Blanks"
		                , "Distinct Values"
		                , "Row Count"
		                , "% Distinct"
		                , "NullCount"
		                , "% Null"
		                , "BlankCount"
		                , "% Blank"
		                , "Min"
		                , "Max"
		                , "Average"
		                , "Median"
		                , "Mode"
		                , "StandardDeviation"
		            }),
		
		        Output                          = #"Reorder Columns"
		    in
		        Output
		        , fx_Type = type function
		        (
		            p_SourceTable as table
		            , optional p_ColumnName as text
		            , optional p_TableName as text
		        ) as table meta
		        [
		            Documentation.Name          = "fx_TableProfile"
		            , Documentation.Description = "This function takes a tabe, runs the Table.Profile function against it, and adds some additional profiling information.<br>Optionally add a column name p_ColumnName to only run profiling against that column.<br>p_TableName is not required and is only included to support fx_DatasetProfile. <br><br> This function relies on the function fx_Loop existing in the dataset."
		            , Documentation.Examples    = 
		            {
		                [
		                    Description         = "Example usage of fx_TableProfile against an entire table."
		                    , Code              = "fx_TableProfile(Sales)"
		                    , Result            = "A table containing the result of Table.Profile(Sales), plus % Null, % Distinct, % Blank, and an errors column calling out the errors found for each column."
		                ],
		                [
		                    Description         = "Example usage of fx_TableProfile against the Order Number column from the Sales table."
		                    , Code              = "fx_TableProfile(Sales, ""Order Number"")"
		                    , Result            = "A table containing the result of Table.Profile(Sales) for the Order Number column, plus % Null, % Distinct, % Blank, and an errors column calling out the errors found for the Order Number column."
		                ]
		            }
		        ]
		in
		Value.ReplaceType(fx, fx_Type)
		```
	lineageTag: 09a9f9fe-63d4-45e4-b351-11c46a8b1a61
	queryGroup: Functions

