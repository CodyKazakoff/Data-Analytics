expression fx_CreateCalendar = ```
		let
		    fx = (p_DateList as list, optional p_FirstFiscalPeriod as number) => let
		        /*  
		            Find the start date and end date of the fact table
		        */
		        StartDate                                               = Date.From(List.Min(p_DateList)),
		        EndDate                                                 = Date.From(List.Max(p_DateList)),
		        
		        // Load the distinct list of dates from the start date to end date and sort the table
		        ListDates                                               = List.Dates(StartDate, Number.From(EndDate - StartDate) + 1, #duration(1,0,0,0)),
		        #"Load Distinct All Dates"                              = Table.FromList(ListDates, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
		        #"Renamed Columns"                                      = Table.RenameColumns(#"Load Distinct All Dates",{{"Column1", "Date"}}),
		        #"Sorted Rows by Date Asc"                              = Table.Sort(#"Renamed Columns",{{"Date", Order.Ascending}}),
		        
		        // Add business friendly columns
		        #"Added Calendar Year"                                  = Table.AddColumn(#"Sorted Rows by Date Asc", "Year", each Date.Year([Date])),
		        #"Added Calendar Month of Year"                         = Table.AddColumn(#"Added Calendar Year", "Month of Year", each Text.Range(Date.MonthName([Date]), 0, 3)),
		        #"Added Calendar Month of Year Long"                    = Table.AddColumn(#"Added Calendar Month of Year", "Month of Year Long", each Date.MonthName([Date])),
		        #"Added Calendar Month Num"                             = Table.AddColumn(#"Added Calendar Month of Year Long", "Month Num", each Date.Month([Date])),
		        #"Added Calendar Quarter of Year"                       = Table.AddColumn(#"Added Calendar Month Num", "Quarter of Year", each "Q" & Number.ToText(Number.RoundUp([Month Num] / 3))),
		        #"Added Calendar Week of Year"                          = Table.AddColumn(#"Added Calendar Quarter of Year", "Week of Year", each Date.WeekOfYear([Date])),
		        #"Added Calendar Month"                                 = Table.AddColumn(#"Added Calendar Week of Year", "Month", each Text.From([Year]) &"-"& [Month of Year]),
		        #"Added Calendar Quarter"                               = Table.AddColumn(#"Added Calendar Month", "Quarter", each Text.From([Year]) &"-"& [Quarter of Year]),
		        #"Added Calendar Week"                                  = Table.AddColumn(#"Added Calendar Quarter", "Week", each Text.From([Year]) &"-W"& Text.From([Week of Year])),
		        #"Added Calendar Weekday"                               = Table.AddColumn(#"Added Calendar Week", "Weekday", each Text.Range(Date.DayOfWeekName([Date]), 0, 3)),
		        #"Added Calendar Weekday Num"                           = Table.AddColumn(#"Added Calendar Weekday", "Weekday Num", each Date.DayOfWeek([Date])),
		        #"Added Calendar Week Ending Date"                      = Table.AddColumn(#"Added Calendar Weekday Num", "Week Ending Date", each Date.EndOfWeek([Date])),
		        
		        // Add [Day of...] columns to enable time based variables 
		        #"Added Calendar Day of Year"                           = Table.AddColumn(#"Added Calendar Week Ending Date", "Day of Year", each Date.DayOfYear([Date])),
		        #"Added Calendar Day of Quarter"                        = Table.AddColumn(#"Added Calendar Day of Year", "Day of Quarter", each Number.From([Date]) - Number.From(Date.StartOfQuarter([Date])) + 1),
		        #"Added Calendar Day of Month"                          = Table.AddColumn(#"Added Calendar Day of Quarter", "Day of Month", each Date.Day([Date])),
		        
		        // Add  Index columns to enable time based variables and sorting of business friendly columns
		        // Year  Index is redundant with Year
		        //#"Added Calendar Year Index"                           = Table.AddColumn(#"Added Calendar Day of Month", "Year Index", each [Year]),
		        // Quarter & Month  Index is useful for sorting in UI
		        #"Added Calendar Quarter Index"                          = Table.AddColumn(#"Added Calendar Day of Month", "Quarter Index", each [Year] * 4 + Number.RoundUp([Month Num] / 3)),
		        #"Added Calendar Month Index"                            = Table.AddColumn(#"Added Calendar Quarter Index", "Month Index", each [Year] * 12 + Date.Month([Date])),
		        // Add Week Index column
		        #"Filtered Rows to Sundays only"                        = Table.SelectColumns(Table.SelectRows(#"Added Calendar Month Index", each ([Weekday] = "Sun")), "Week Ending Date"),
		        #"Created Week Index"                                    = Table.AddIndexColumn(#"Filtered Rows to Sundays only", "TempWeek Index", 2, 1),
		        #"Merged Queries Master Calendar to Week Index"          = Table.NestedJoin(#"Added Calendar Month Index",{"Week Ending Date"},#"Created Week Index",{"Week Ending Date"},"Added  Index WeekNum",JoinKind.LeftOuter),
		        #"Expanded to add Week Index"                            = Table.ExpandTableColumn(#"Merged Queries Master Calendar to Week Index", "Added  Index WeekNum", {"TempWeek Index"}, {"TempWeek Index"}),
		        #"Replaced nulls with 1s in Week Index"                  = Table.AddColumn(#"Expanded to add Week Index", "Week Index", each if [TempWeek Index] = null 
		            then 1
		            else [TempWeek Index]),
		        #"Removed TempWeek Index"                                = Table.RemoveColumns(#"Replaced nulls with 1s in Week Index",{"TempWeek Index"}),
		        
		        #"Added Calendar Date Index"                             = Table.AddColumn(#"Removed TempWeek Index", "Date Index", each Number.From([Date])),
		        
		        #"Added Calendar DateKey"                               = Table.AddColumn(#"Added Calendar Date Index", "Date Key", each Date.ToText([Date], "YYYYMMDD"), Int64.Type),
		
		        #"Added Fiscal Year" 
		            = Table.AddColumn(#"Added Calendar DateKey", "Fiscal Year"
		            , each 
		                if p_FirstFiscalPeriod <> null
		                    then if [Month Num] >= p_FirstFiscalPeriod
		                        then [Year]+1
		                        else [Year]
		                    else
		                        [Year]
		        ),
		
		        #"Added Fiscal Period Num" 
		            = Table.AddColumn(#"Added Fiscal Year", "Fiscal Period Num"
		            , each
		                if p_FirstFiscalPeriod <> null
		                    then if [Month Num] >= p_FirstFiscalPeriod
		                        then [Month Num]-(p_FirstFiscalPeriod-1)
		                        else [Month Num]+(12-p_FirstFiscalPeriod+1)
		                    else [Month Num]
		        ),
		
		        #"Added Fiscal Period"                                  = Table.AddColumn(#"Added Fiscal Period Num", "Fiscal Period", each Text.From([Fiscal Year]) &"-"& Text.PadStart(Text.From([Fiscal Period Num]), 2, "0")),
		
