	partition 'test_Active Employees Year Ago' = calculated
		mode: import
		source = ```
				
				VAR OneYearAgo = EDATE(MAX(_Date_Table[Date]), -12)
				RETURN
				SELECTCOLUMNS(
				    FILTER(
				        D_Employee,
				        D_Employee[DATE_HIRED] <= OneYearAgo
				        && (
				            D_Employee[DATE_TERMINATED] = DATE(1900,1,1)
				            || D_Employee[DATE_TERMINATED] > OneYearAgo
				        )
				        && CONTAINSSTRING(D_Employee[EMP_DEPT], "DP")
				    ),
				    "Employee ID", D_Employee[EMPLOYEE_ID],
				    "Employee Name", D_Employee[EMP_NAME_CN],
				    "Date Hired", D_Employee[DATE_HIRED],
				    "Date Terminated", D_Employee[DATE_TERMINATED],
				    "One Year Ago Date", OneYearAgo,
				    "Location", D_Employee[EMP_DEPT]
				)
				
				```

	annotation PBI_Id = 3a80ed3277ab4cf6b01285d29ba13faa

