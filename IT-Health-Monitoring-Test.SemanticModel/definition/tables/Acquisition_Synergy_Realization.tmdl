		annotation SummarizationSetBy = Automatic

	column Format_Flag =
			IF(
			    DATEVALUE('Acquisition_Synergy_Realization'[Realization Time Horizon]) >= TODAY() &&
			    'Acquisition_Synergy_Realization'[Unrealized_Savings] / Acquisition_Synergy_Realization[Target Savings] > 0.75,
			    1,
			    0
			)
		formatString: 0
