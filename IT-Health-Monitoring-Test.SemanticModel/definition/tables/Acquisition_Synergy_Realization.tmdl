	column Unrealized_Savings = 'Acquisition_Synergy_Realization'[Target Savings] - Acquisition_Synergy_Realization[Savings Realized to Date]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 96412d95-1f22-49c6-b935-e41569af4b42
