	measure Employee_Count_One_Year_Ago = ```
			
			VAR OneYearAgo = EDATE(MAX(_Date_Table[Date]), -12)
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(D_Employee[EMPLOYEE_ID]),
			    CONTAINSSTRING(D_Employee[EMP_DEPT], "DP"),
			    D_Employee[DATE_HIRED] <= OneYearAgo,                          // Hired on or before one year ago
			    D_Employee[DATE_TERMINATED] > OneYearAgo                       // Still employed one year ago
			        || D_Employee[DATE_TERMINATED] = DATE(1900,1,1)            // Or date placeheld with placeholder 
			)
			
			
			```
		formatString: 0
		lineageTag: b45eff6b-70b5-46af-826d-0b0305543cfa

