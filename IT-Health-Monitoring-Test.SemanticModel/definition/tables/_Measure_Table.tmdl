	measure Sales_Growth_YoY_Digital_Card = ```
			
			VAR CurrentYear = YEAR(TODAY())
			VAR CurrentYearSales = 
			    CALCULATE(
			        [Sales_YTD_AsOfToday_Digital],
			        '_Date_Table'[Year] = CurrentYear
			    )
			VAR PriorYearSales = 
			    CALCULATE(
			        [Sales_YTD_AsOfToday_Digital],
			        '_Date_Table'[Year] = CurrentYear - 1
			    )
			RETURN
			IF(
			    NOT(ISBLANK(PriorYearSales)),
			    DIVIDE(
			        (CurrentYearSales - PriorYearSales),
			        PriorYearSales,
			        BLANK()
			    ),
			    BLANK()
			)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: ab2957cf-7b9e-4c0b-bf50-5f94fe3a2970

	measure PI_Calculated = ```
			
			VAR CurrentDate = MAX(D_Calendar[CALENDAR_DATE])
			VAR PI1Start = DATE(2023, 11, 9)
			VAR PI2Start = DATE(2024, 3, 21)
			VAR PI3Start = DATE(2024, 6, 20) 
			VAR PI4Start = DATE(2024, 9, 18)  
			VAR PI5Start = DATE(2024, 12, 12)  
			VAR PI6Start = DATE(2025, 3, 6)
			RETURN
			SWITCH(
			    TRUE(),
			    CurrentDate >= PI6Start, 6,
			    CurrentDate >= PI5Start, 5,
			    CurrentDate >= PI4Start, 4,
			    CurrentDate >= PI3Start, 3,
			    CurrentDate >= PI2Start, 2,
			    CurrentDate >= PI1Start, 1,
			    BLANK()
			)
			
			```
		formatString: 0
		lineageTag: cd996566-de17-49e0-9b7d-dfa4d427f13d

