	measure Frequency_Delivery_Details =
			
			VAR BugCount = CALCULATE(
			    COUNT(Delivery_Details[Work Item Id]),
			    Delivery_Details[Work Item Type] = "Bug"
			)
			VAR PIRCount = CALCULATE(
			    COUNT(Delivery_Details[Work Item Id]),
			    Delivery_Details[Work Item Type] = "PIR"
			)
			VAR UserStoryCount = CALCULATE(
			    COUNT(Delivery_Details[Work Item Id]),
			    Delivery_Details[Work Item Type] = "User Story"
			)
			RETURN
			  BugCount + PIRCount + UserStoryCount
		formatString: 0
		lineageTag: 280c4b84-5007-47fc-9f50-2705db71f0cd

	measure 'DORA_Failure_Rate (CFRP Measure)' =
			
			VAR BugCount = CALCULATE(
			    COUNT(Append1[WorkItemId]),
			    Append1[WorkItemType] = "Bug"
			)
			VAR PIRCount = CALCULATE(
			    COUNT(Append1[WorkItemId]),
			    Append1[WorkItemType] = "PIR"
			)
			RETURN
			    DIVIDE(BugCount, PIRCount)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 09882ed7-a27a-4c0e-895c-14cd3d8b7a03

