			        DATESINPERIOD(
			            '_Date_Table'[Date],
			            MAX('_Date_Table'[Date]),
			            -12,
			            MONTH
			        )
			    )
			VAR PreviousPeriod = 
			    CALCULATE(
			        [Sales],
			        DATESINPERIOD(
			            '_Date_Table'[Date],
			            EDATE(MAX('_Date_Table'[Date]), -12),
			            -12,
			            MONTH
			        )
			    )
			RETURN
			    DIVIDE(
			        CurrentPeriod - PreviousPeriod,
			        PreviousPeriod,
			        BLANK()
			    )
			
