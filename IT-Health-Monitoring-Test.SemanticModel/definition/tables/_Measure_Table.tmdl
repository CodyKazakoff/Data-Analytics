	measure Sales = ```
			
			CALCULATE(
			    SUM('F_Shipper_Item'[SALES_AMOUNT]),
			    FILTER(
			        'F_Shipper_Item',
			        'F_Shipper_Item'[SALES_POSTED_DATE] < EOMONTH(TODAY(), -1) + 1
			    )
			)
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: e3127b64-1e01-404b-9835-0c9f50279ded

	measure Sales_to_Date = ```
			CALCULATE(
