	measure Sales_Growth_YoY_Table = ```
			
			VAR CurrentYear = YEAR(TODAY())
			VAR CurrentYearSales = [Sales_YTD_AsOfToday]
			VAR PriorYear = CALCULATE(
			    [Sales_YTD_AsOfToday],
			    SAMEPERIODLASTYEAR('_Date_Table'[Date])
			)
			VAR PctChange = DIVIDE((CurrentYearSales - PriorYear), PriorYear)
			RETURN
			    IF(ISBLANK(PctChange), "", PctChange)
			
			```
		lineageTag: 18fb5d57-d02f-47bd-a0cb-abc2ee4f49be

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Sales_Prior_Year =
			CALCULATE(
