			    'Delivery_Details_New'[Work Item Type] = "Team PI Objective",
			    'Delivery_Details_New'[PI_Current_Iteration_Path_Int] > 3, 
			    'Delivery_Details_New'[PI_Current_Iteration_Path_Int] < CurrentPI
			    )
