	measure Employee_Starting_Count = ```
			
			VAR CurrentYear = YEAR(MAX('_Date_Table'[Date]))
			RETURN
			CALCULATE(
			    COUNTROWS(D_Employee),
			    FILTER(
			        D_Employee,
			        VALUE(D_Employee[DATE_HIRED]) < DATE(CurrentYear, 1, 1)
			        && (VALUE(D_Employee[DATE_TERMINATED]) = DATE(1900, 1, 1) 
			            || VALUE(D_Employee[DATE_TERMINATED]) >= DATE(CurrentYear, 1, 1))
			    )
			)
			
			```
		formatString: 0
		lineageTag: 07ce3e67-efa3-469f-91c0-fad05eb9c181

	measure Employee_Count_New_Hires_Current_Year = ```
			
			VAR OneYearAgo = EDATE(MAX(_Date_Table[Date]), -12)
			RETURN
			CALCULATE(
			    COUNTROWS(D_Employee),
			    D_Employee[DATE_HIRED] > OneYearAgo,
			    CONTAINSSTRING(D_Employee[EMP_DEPT], "DP")
			)
			
			
			```
		formatString: 0
		lineageTag: 2d5e61ca-5a05-400e-9e65-bc236d9f7a28

	measure Employee_Count_Exits_Past_Year = ```
			
			VAR OneYearAgo = EDATE(MAX(_Date_Table[Date]), -12)
			VAR CurrentDate = MAX(_Date_Table[Date])
			RETURN
			CALCULATE(
			    COUNTROWS(D_Employee),
			    D_Employee[DATE_TERMINATED] > OneYearAgo,
			    D_Employee[DATE_TERMINATED] <= CurrentDate,
			    D_Employee[DATE_TERMINATED] <> DATE(1900,1,1),
			    CONTAINSSTRING(D_Employee[EMP_DEPT], "DP")
			)
			
			
			```
		formatString: 0
		lineageTag: 539c09a9-d3a3-4211-815f-af73bc07803c

	measure Employee_Count_Total_Active_IT = ```
			
			CALCULATE(
			    DISTINCTCOUNT(D_Employee[EMPLOYEE_ID]),
			    CONTAINSSTRING(D_Employee[EMP_DEPT], "DP"),
			    D_Employee[DATE_TERMINATED] = DATE(1900, 1, 1)
			)
			    
			
