	partition _Date_Table = calculated
		mode: import
		source = ```
				
				VAR StartDate = DATE(2021, 1, 1)
				VAR EndDate = TODAY()  
				RETURN
				ADDCOLUMNS(
				    CALENDAR(StartDate, EndDate),
				    "Month", MONTH([Date]),
				    "Year", YEAR([Date]),
				    "Year_Text", FORMAT([Date], "YYYY"),
				    "Month_Year", FORMAT([Date], "MMM-yyyy"),
				    "Month_Year_Sort", YEAR([Date]) * 100 + MONTH([Date]),
				    "Month_Name", FORMAT([Date], "MMMM"),
				    "Month_Name_Sort", MONTH([Date]),
				    "Quarter_Year", "Q" & FORMAT([Date], "q") & " " & FORMAT(YEAR([Date]), "0000"),
				    "Quarter_Year_Sort", YEAR([Date]) * 10 + ROUNDDOWN((MONTH([Date])-1)/3, 0),
				    "PI", 
				        SWITCH(
				            TRUE(),
				            // PI 2
				            AND(
				                [Date] >= DATE(2024, 3, 21),
				                [Date] <= DATE(2024, 6, 12)
				            ), "PI 2",
				            // PI 3
				            AND(
				                [Date] >= DATE(2024, 6, 20),
				                [Date] <= DATE(2024, 9, 11)
				            ), "PI 3",
				            // PI 4
				            AND(
				                [Date] >= DATE(2024, 9, 19),
				                [Date] <= DATE(2024, 12, 4)
				            ), "PI 4",
				            // PI 5
				            AND(
				                [Date] >= DATE(2024, 12, 12),
				                [Date] <= DATE(2025, 2, 26)
				            ), "PI 5",
				            // PI 6
				            AND(
				                [Date] >= DATE(2025, 3, 6),
				                [Date] <= DATE(2025, 6, 4)
				            ), "PI 6",
				            // PI 7
				            AND(
				                [Date] >= DATE(2025, 6, 12),
				                [Date] <= DATE(2025, 9, 10)
				            ), "PI 7",
				            // Default value for dates not in any PI period
				            BLANK()
				        ),
				    "PI_Number", 
				        SWITCH(
				            TRUE(),
				            // PI 2
				            AND(
				                [Date] >= DATE(2024, 3, 21),
				                [Date] <= DATE(2024, 6, 12)
				            ), "2",
				            // PI 3
				            AND(
				                [Date] >= DATE(2024, 6, 20),
				                [Date] <= DATE(2024, 9, 11)
				            ), "3",
				            // PI 4
				            AND(
				                [Date] >= DATE(2024, 9, 19),
				                [Date] <= DATE(2024, 12, 4)
				            ), "4",
				            // PI 5
				            AND(
				                [Date] >= DATE(2024, 12, 12),
				                [Date] <= DATE(2025, 2, 26)
				            ), "5",
				            // PI 6
				            AND(
				                [Date] >= DATE(2025, 3, 6),
				                [Date] <= DATE(2025, 6, 4)
				            ), "6",
				            // PI 7
				            AND(
				                [Date] >= DATE(2025, 6, 12),
				                [Date] <= DATE(2025, 9, 10)
				            ), "7",
				            BLANK()
				        )
				)
				
				```

	annotation PBI_Id = 511f1e50a2044937980ab67f4e68d51d

