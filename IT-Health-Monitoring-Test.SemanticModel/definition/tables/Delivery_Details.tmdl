	column Closed_PI =
			
			SWITCH(
			    TRUE(),
			    ISBLANK(Delivery_Details[Closed Date]), "",
			    AND(Delivery_Details[Closed Date] >= DATE(2024,6,20), Delivery_Details[Closed Date] <= DATE(2024,9,11)), "PI 3",
			    AND(Delivery_Details[Closed Date] >= DATE(2024,9,19), Delivery_Details[Closed Date] <= DATE(2024,12,4)), "PI 4",
			    AND(Delivery_Details[Closed Date] >= DATE(2024,12,12), Delivery_Details[Closed Date] <= DATE(2025,2,26)), "PI 5",
			    FORMAT(Delivery_Details[Closed Date], "yyyy-MM-dd")
			)
		lineageTag: 549cd040-f449-40c2-8f34-01e4c26cd013
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

