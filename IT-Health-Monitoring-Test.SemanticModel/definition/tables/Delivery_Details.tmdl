	column 'Customer Score'
		dataType: int64
		formatString: 0
		lineageTag: d6af73c1-d848-4b46-b147-6e80af000551
		summarizeBy: sum
		sourceColumn: Customer Score

		annotation SummarizationSetBy = Automatic

	partition Delivery_Details = m
		mode: import
		source = ```
				let
				    Source = VSTS.AnalyticsViews("https://dev.azure.com/Motion-IT", "MI-Dev", []),
				    #"Private Views_Folder" = Source{[Id="Private Views",Kind="Folder"]}[Data],
				    #"84bf7497-d0a0-489e-a8a0-a27afe584147_Table" = #"Private Views_Folder"{[Id="84bf7497-d0a0-489e-a8a0-a27afe584147",Kind="Table"]}[Data],
				    #"Changed Type" = Table.TransformColumnTypes(#"84bf7497-d0a0-489e-a8a0-a27afe584147_Table",{{"Activated Date", type date}}),
				    #"Added Conditional Column" = Table.AddColumn(#"Changed Type", "Temp Column", each if [Title] = "Certify Tax " then "At Risk" else [Tags]),
				    #"Removed Columns" = Table.RemoveColumns(#"Added Conditional Column",{"Tags"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"Temp Column", "Tags"}}),
				    #"Added Conditional Column1" = Table.AddColumn(#"Renamed Columns", "Team", each if [Area Path] = "MI-Dev\Data Solutions\Analytics" then "Data & Analytics" else if [Area Path] = "MI-Dev\Cloud Services" then "Cloud Services" else if [Area Path] = "" then "Data Integration" else if [Area Path] = "MI-Dev\E-Apps\eCOS-Finance" then "Finance" else [Area Path]),
				    ExtractPI = (path) => let 
				       parts = Text.Split(path, "\"),  
				       piPart = List.Select(parts, each Text.Contains(_, "PI ")),  
				       cleanedPI = if List.Count(piPart) > 0 then  
				           let  
				               pi = piPart{0},  
				               piNumber = Text.Select(Text.AfterDelimiter(pi,"PI "), {"0".."9"}),  
				               result = "PI " & piNumber  
				               in  
				                   result  
				       else  
				           null  
				   in
				       cleanedPI,
				   #"Added PI Column" = Table.AddColumn(#"Added Conditional Column1", "PI_Extract_Function", each ExtractPI([Iteration Path])),
				    #"Renamed Columns1" = Table.RenameColumns(#"Added PI Column",{{"PI_Extract_Function", "PI_Extract"}}),
				    #"Filtered Rows1" = Table.SelectRows(#"Renamed Columns1", each ([PI_Extract] <> null)),
				    ExtractCommittedPI = (path, piExtract) => let
				        committedPI = if path = null then
				            piExtract
				        else
				            let
				                parts = Text.Split(path, "\"),
				                sprintPart = List.Select(parts, each Text.StartsWith(_, "Sprint ")),
				                result = if List.Count(sprintPart) > 0 then
				                    let
				                        sprint = sprintPart{0},
				                        sprintNumber = Text.Select(Text.AfterDelimiter(sprint, "Sprint "), {"0".."9", "."}),
				                        firstNumber = Text.BeforeDelimiter(sprintNumber, ".")
				                    in
				                        "PI " & firstNumber
				                else
				                    piExtract
				            in
				                result
				    in
				        committedPI,
				    #"Added Committed PI" = Table.AddColumn(#"Filtered Rows1", "Committed_PI", each if [Committed Objective] = false then "" else ExtractCommittedPI([Original Iteration Path], [PI_Extract])),
				    #"Added Custom" = Table.AddColumn(#"Added Committed PI", "Custom", each if Text.Contains([Committed_PI], " ") then
				    let
				        part = Text.AfterDelimiter([Committed_PI], " "),
				        num = try Number.From(part) otherwise null
				    in
				        num
				  else
				    let
				        digits = Text.Select([Committed_PI], {"0".."9"}),
				        num = try Number.From(digits) otherwise null
				    in
				        num),
				    #"Renamed Columns2" = Table.RenameColumns(#"Added Custom",{{"Custom", "Committed_PI_Int"}})
				in 
				    #"Renamed Columns2"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

