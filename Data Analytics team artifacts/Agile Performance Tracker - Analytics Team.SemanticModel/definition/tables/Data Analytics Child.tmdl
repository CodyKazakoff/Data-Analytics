table 'Data Analytics Child'
	lineageTag: 903f8533-8a5a-4306-a3b7-304cb95a01c5

	measure 'Buffer Story Points' =
			DIVIDE(CALCULATE(
			    SUM('Data Analytics Child'[Story Points]),
			    FILTER(
			        'Data Analytics Parent',
			        'Data Analytics Parent'[Title] = "Data Analytics 2024 Enhancements" ||
			        'Data Analytics Parent'[Title] = "Data Analytics 2024 Support" ||
			        'Data Analytics Parent'[Title] = "Data Analytics 2024 Technical Enablement"
			    )
			),
			DISTINCTCOUNT('Data Analytics Child'[Iteration Path]))
		lineageTag: 662db7e1-995c-4fee-bbab-2c8a80da8aff

		annotation PBI_FormatHint = {"isGeneralNumber":true}

