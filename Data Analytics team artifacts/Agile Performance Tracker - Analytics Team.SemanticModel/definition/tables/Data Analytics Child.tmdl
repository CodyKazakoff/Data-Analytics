	partition 'Data Analytics Child' = m
		mode: import
		source =
				let
				    Source = VSTS.AnalyticsViews("Motion-IT", "MI-Dev", []),
				    #"Shared Views_Folder" = Source{[Id="Shared Views",Kind="Folder"]}[Data],
				    #"2eb3da31-f1a6-4d15-852b-51ce30dd414f_Table" = #"Shared Views_Folder"{[Id="2eb3da31-f1a6-4d15-852b-51ce30dd414f",Kind="Table"]}[Data],
				    #"Added Custom" = Table.AddColumn(#"2eb3da31-f1a6-4d15-852b-51ce30dd414f_Table", "Path_Assignee [Tasks]", each [Iteration Path] & "-" & [Assigned To])
				in
				    #"Added Custom"

	annotation PBI_ResultType = Table

