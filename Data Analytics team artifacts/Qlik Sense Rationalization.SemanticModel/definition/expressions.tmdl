expression fx_CreateDimDate = ```
		let
		    Source = let
		    fx = (p_DateList as list) => let
		        Source = #"fx_CreateCalendar"(p_DateList),
		        Output = Table.Distinct(Table.SelectColumns(Source,{"Date", "Weekday", "Weekday Num", "Day of Year", "Date Index", "Date Key", "Day of Quarter", "Day of Month"}))
		    in
		        Output,
		        fx_Type = type function
		        (
		            p_DateList as list
		        ) as table meta
		        [
		            Documentation.Name = "fx_CreateDimDate"
		            , Documentation.Description = "This function takes a list of dates and generates all possible dates between the min and max date provided using fx_CreateCalendar, then keeps only the Date level columns"
		            , Documentation.Examples = 
		            {
		                [
		                    Description = "Example usage of fx_CreateDimDate without first fiscal period"
		                    , Code = "fx_CreateDimDate(Sales[Date])"
		                    , Result = "A table containing all date level calendar information between the min and max dates from the date list provided"
		                ]
		            }
		        ]
		in
		Value.ReplaceType(fx, fx_Type)
		in
		    Source
		```
