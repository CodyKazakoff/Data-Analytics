expression fx_FilterDimByFact = ```
		let
		  fx = (p_FactTable as table, p_FactForeignKeyFieldName as text, p_DimTable as table, p_DimTableKeyFieldName as text) => let
		        #"Fact Joined Table Name" = Text.Combine({p_FactForeignKeyFieldName, " - Joined"}),
		        #"Get Distinct Keys from Fact" = Table.Distinct(Table.SelectColumns(p_FactTable, {p_FactForeignKeyFieldName})),
		        #"Merged Queries" = Table.NestedJoin(p_DimTable, {p_DimTableKeyFieldName}, #"Get Distinct Keys from Fact", {p_FactForeignKeyFieldName}, #"Fact Joined Table Name", JoinKind.Inner),
		        #"Expanded Foreign Key - Joined" = Table.ExpandTableColumn(#"Merged Queries", #"Fact Joined Table Name", {p_FactForeignKeyFieldName}, {#"Fact Joined Table Name"}),
		        Output = Table.RemoveColumns(#"Expanded Foreign Key - Joined",{#"Fact Joined Table Name"})
		    in
		        Output,
		  fx_Type = type function
		        (
		            p_FactTable as table
		            , p_FactForeignKeyFieldName as text
		            , p_DimTable as table
		            , p_DimTableKeyFieldName as text
		        ) as table meta
		        [
		            Documentation.Name          = "fx_FilterDimByFact"
		            , Documentation.Description = "This function will filter a dimension table based on the unique list of key values from an associated fact table. This function is foldable."
		            , Documentation.Examples    = 
		            {
		                [
		                    Description         = "Example usage of fx_FilterDimByFact."
		                    , Code              = "fx_FilterDimByFact(#""FactInternestSales"", ""CustomerKey"", ""dbo_DimCustomer"", ""CustomerKey"")"
		                    , Result            = "A filtered down version of dbo_DimCustomer to only the matching values between #""dbo_DimCustomer""[CustomerKey] in #""FactInternestSales""[CustomerKey]"
		                ]
		            }
		        ],
		  fx_Output = Value.ReplaceType(fx, fx_Type)
		in
		  fx_Output
		```
