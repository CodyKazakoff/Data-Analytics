	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression fx_TestRelationship = ```
		let
		    fx = (p_Column1 as list, p_Column2 as list) => let
		
		        //Column 1 Info
		        #"Table 1 Source"               = Table.FromList(p_Column1, Splitter.SplitByNothing(), {"Table 1 Key"}, null, ExtraValues.Error),
		        #"Table 1 Grouped Rows"         = Table.Group(#"Table 1 Source", {"Table 1 Key"}, {{"Table 1 Instance Count", each Table.RowCount(_), Int64.Type}}),
		
		        //Column 2 Info
		        #"Table 2 Source"               = Table.FromList(p_Column2, Splitter.SplitByNothing(), {"Table 2 Key"}, null, ExtraValues.Error),
		        #"Table 2 Grouped Rows"         = Table.Group(#"Table 2 Source", {"Table 2 Key"}, {{"Table 2 Instance Count", each Table.RowCount(_), Int64.Type}}),
		
		        #"Joined Tables"                = Table.NestedJoin(#"Table 1 Grouped Rows", {"Table 1 Key"}, #"Table 2 Grouped Rows", {"Table 2 Key"}, "Output", JoinKind.FullOuter),
		        #"Expanded Output"              = Table.ExpandTableColumn(#"Joined Tables", "Output", {"Table 2 Key", "Table 2 Instance Count"}),
		
		        #"Table 1 Null Ind"             = Table.AddColumn(#"Expanded Output", "Table 1 Null Ind", each if [Table 1 Key] = null then 1 else 0),
		        #"Table 2 Null Ind"             = Table.AddColumn(#"Table 1 Null Ind", "Table 2 Null Ind", each if [Table 2 Key] = null then 1 else 0),
		        #"Grouped Rows Null Ind"        = Table.Group(#"Table 2 Null Ind"
		                                            , {}
		                                            , {
		                                                {"Table 1 Null Count", each List.Sum([Table 1 Null Ind]), type number}
		                                                , {"Table 2 Null Count", each List.Sum([Table 2 Null Ind]), type number}
		                                            }
		                                        ),
		
		        #"Grouped Rows Many Instances"  = Table.Group(#"Expanded Output"
		                                                , {}
		                                                , {
		                                                    {"Table 1 Has Many Instances", each List.Max([Table 1 Instance Count]), type number}
		                                                    , {"Table 2 Has Many Instances", each List.Max([Table 2 Instance Count]), type number}
		                                                }
		                                            ),
		
		        #"Output"                       = Table.FromRecords({
		                                                [
		                                                    Relationship = Text.Combine(
		                                                        {
		                                                            if #"Grouped Rows Many Instances"[Table 1 Has Many Instances]{0} > 1 then "m" else "1"
		                                                            , if #"Grouped Rows Null Ind"[Table 1 Null Count]{0} > 0 then " or 0" else ""
		                                                            , ":"
		                                                            , if #"Grouped Rows Many Instances"[Table 2 Has Many Instances]{0} > 1 then "m" else "1"
		                                                            , if #"Grouped Rows Null Ind"[Table 2 Null Count]{0} > 0 then " or 0" else ""
		                                                        }
		                                                    )
		                                                ]
		                                            })
		    in
		        Output,
		        fx_Type = type function
		        (
		            p_Column1 as list
		            , p_Column2 as list
		        ) as table meta
		        [
		            Documentation.Name = "fx_TestRelationship"
