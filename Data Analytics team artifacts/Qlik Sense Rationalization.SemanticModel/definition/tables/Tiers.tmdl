				    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"Name", "App"}, {"Activity Index", "Activity_Index"}, {"Automation Ratio", "Automation_Ratio"}, {"Tier", "Tier_old"}, {"Tier Adjusted", "Tier"}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Renamed Columns",{"Tier_old"}),
				    #"Added Activity Bins" = Table.AddColumn(#"Removed Columns", "Activity_Index_Bins", each //Truncating to the first decimal
				        Number.FromText(Text.Start(Number.ToText([Activity_Index]), 3))
				    , type number),
				    #"Added New Tier" = Table.AddColumn(#"Added Activity Bins", "New Tier", each
				        if ([Tier] = "Tier 1" and [Activity_Index] < 0.005)
				        then "Tier 2"
				        else [Tier]
				    , type text),
				    #"Removed Columns1" = Table.RemoveColumns(#"Added New Tier",{"Tier"}),
				    #"Renamed Columns1" = Table.RenameColumns(#"Removed Columns1",{{"New Tier", "Tier"}}),
