	partition Tiers = m
		mode: import
		queryGroup: 'Clustering Calculations'
		source =
				let
				    Source = Csv.Document(File.Contents(SupportingFiles & "\Tiers_Motion_Updated.csv"),[Delimiter=",", Columns=13, Encoding=1252, QuoteStyle=QuoteStyle.None]),
