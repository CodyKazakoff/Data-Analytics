	column 'Activity_Index (bins)' =
			IF(
				ISBLANK('Tiers'[Activity_Index]),
				BLANK(),
				IF(
					'Tiers'[Activity_Index] >= 0,
					ROUNDDOWN('Tiers'[Activity_Index] / 0.1, 0) * 0.1,
					ROUNDUP('Tiers'[Activity_Index] / 0.1, 0) * 0.1
				)
			)
		lineageTag: c877b51f-bdc1-40c9-9aee-603e92faa48e
