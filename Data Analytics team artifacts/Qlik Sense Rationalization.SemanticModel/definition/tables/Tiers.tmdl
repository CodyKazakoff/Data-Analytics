				    #"Expanded activity_index.1" = Table.ExpandTableColumn(#"Merged Queries", "activity_index.1", {"User-facing App Workspace"}, {"Stream"}),
				    #"Sorted Rows" = Table.Sort(#"Expanded activity_index.1",{{"App", Order.Ascending}})
				in
