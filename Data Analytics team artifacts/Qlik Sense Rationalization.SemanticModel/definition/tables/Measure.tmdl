	measure 'Object Count Complexity Adjusted' = ```
			
			VAR vEstimateIndex = SELECTEDVALUE('Estimate Config'[Step Index])
			
			VAR vResult = 
			SWITCH(vEstimateIndex
			, 0, 1
			, 1, [Dependency Count]
			, 3, [Input Count]
			, 4, [Output Count]
			, 5, [Table Complexity Multiplier]
			, 6, [Field Count]
			, 7, [Relationship Count]
			, 8, [Measure Complexity Multiplier]
			, 9, [Page Count]
			, 10, [Page Object Complexity Multiplier]
			, 11, [Variable Count]
			, 12, 1
			, 13, [Input Count]
			, 14, [Dependency Count]
			, 15, [Output Count]
			, 16, [Output Count]
			, 17, [Output Count]
			, 18, [Table Complexity Multiplier]
			, 19, [Output Count]
			, 20, [Table Complexity Multiplier]
			, 21, [Table Complexity Multiplier]
			, 22, [Measure Complexity Multiplier]
			, 23, [Table Complexity Multiplier]
			, 24, [Measure Count]
			, 25, [Relationship Count]
			, 26, [Page Count]
			, 27, [Page Object Complexity Multiplier]
			, 28, [Table Complexity Multiplier]
			, 29, [Page Object Complexity Multiplier]
			, 30, [Measure Complexity Multiplier]
			
			)
			
			RETURN vResult
			```
		formatString: #,##0
		lineageTag: ba15e00b-d4ca-4250-8027-994ec09205d9

		annotation PBI_FormatHint = {"isCustom":true}

