	measure 'Object Count' = ```
			
			VAR vEstimateIndex = SELECTEDVALUE('Estimate Config'[Step Index])
			
			VAR vResult = 
			SWITCH(vEstimateIndex
			, 0, 1
			, 1, [Dependency Count]
			, 3, [Input Count]
			, 4, [Output Count]
			, 5, [Table Count]
			, 6, [Field Count]
			, 7, [Relationship Count]
			, 8, [Measure Count]
			, 9, [Page Count]
			, 10, [Page Object Count]
			, 11, [Variable Count]
			, 12, 1
			, 13, [Input Count]
			, 14, [Dependency Count]
			, 15, [Output Count]
			, 16, [Output Count]
			, 17, [Output Count]
			, 18, [Table Count]
			, 19, [Output Count]
			, 20, [Table Count]
			, 21, [Table Count]
			, 22, [Measure Count]
			//, 22, [Measure Complexity Multiplier]
			, 23, [Table Count]
			, 24, [Measure Count]
			, 25, [Relationship Count]
			, 26, [Page Count]
			, 27, [Page Object Count]
			, 28, [Table Count]
			, 29, [Page Object Count]
			, 30, [Measure Count]
			
			)
			
			RETURN vResult
			```
		formatString: #,##0
		lineageTag: 249e1494-7036-4feb-a323-19183d044812

		annotation PBI_FormatHint = {"isCustom":true}

