	measure 'Automated Savings' = SUMX('Estimate Config', [Calculated Per Item Manual Effort (Minutes)] * [Automated Reduction])
		formatString: #,##0.00
		lineageTag: 74f64909-961d-4a84-bee8-663179104627

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Automation Assisted Effort (Minutes)' = [Calculated Per Item Manual Effort (Minutes)] - [Automated Savings]
		formatString: #,##0.00
		lineageTag: 9cc0996a-8362-4538-ba8d-f7ecac16f817

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Automation Ratio' = 1 - ([Automation Assisted Effort (Minutes)] / [Calculated Per Item Manual Effort (Minutes)])
