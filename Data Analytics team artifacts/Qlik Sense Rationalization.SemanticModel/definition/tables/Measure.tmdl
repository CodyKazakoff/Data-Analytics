	measure 'Environment Overview Text Embedding 2' = ```
			
			
			VAR _user_number = IF(
			    SELECTEDVALUE(Tiers[Tier]) = BLANK(),
			    Format(DISTINCTCOUNT('App Usage'[User ID]),"#,##0"),
			    FORMAT(DISTINCTCOUNT('App Usage'[User ID]) / Calculate(DISTINCTCOUNT('App Usage'[User ID]),REMOVEFILTERS(Tiers[Tier])), "Percent")
			)
			
			VAR _session_number = IF(
			    SELECTEDVALUE(Tiers[Tier]) = BLANK(),
			    Format(COUNT('App Usage'[AppId]),"#,##0"),
			    FORMAT(Divide(COUNT('App Usage'[AppId]),  Calculate(COUNT('App Usage'[AppId]),REMOVEFILTERS(Tiers[Tier]))), "Percent")
			)
			
			// CASE 1: The environment has a total of X users and Y sessions
			VAR _case1 = CONCATENATE(
			    CONCATENATE(CONCATENATE('Measure'[SelectedTiers2], "has a user base of "), CONCATENATE(_user_number, " users, contributing to ")), 
			    CONCATENATE(_session_number, " total Qlik sessions.")
			)
			
			// CASE 2: Tier X consists of X% of users and Y% of all sessions
			VAR _case2 = CONCATENATE(
			    CONCATENATE(CONCATENATE('Measure'[SelectedTiers2], " contains "), CONCATENATE(_user_number, " of all distinct users, which contribute to " )),
			    CONCATENATE(_session_number, " of all Qlik sessions.")
			)
			
			RETURN IF(
			    SELECTEDVALUE(Tiers[Tier]) = BLANK(),
			    _case1,
			    _case2
			)
			// RETURN IF(
			//     SELECTEDVALUE(Tiers[Tier]) <1,
			//     _case1,
			//     _case2
			// )
			```
		lineageTag: bded3f8e-3b83-4fdc-a2fa-bde64959f981

