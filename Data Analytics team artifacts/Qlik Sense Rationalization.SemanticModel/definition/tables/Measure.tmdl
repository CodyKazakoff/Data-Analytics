	measure 'Page Object Count' =
			
			CALCULATE(
			    COUNTROWS('Page Object')
			    , 'App'[App Type] = "UI"
			)
		formatString: #,##0
		lineageTag: cf2c04fc-af7d-48da-8f2b-7ccf1ddd6ddc

