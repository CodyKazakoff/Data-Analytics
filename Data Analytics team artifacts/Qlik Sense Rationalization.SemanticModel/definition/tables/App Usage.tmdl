		sortByColumn: MonthIndex

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Users = Calculate(Countx('App Usage','App Usage'[User ID]), GROUPBY('App Usage', 'App Usage'[Month], 'App Usage'[App]))
		formatString: 0
		lineageTag: d70a0bf4-b90d-42c1-a9e6-66c5313f3459
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Active app' =
			
			var halfyear = Month(Today())-6
			var calc = IF(Year('App Usage'[Date]) <> Year(Today()), "No",
			                IF(Month('App Usage'[Date]) < halfyear, "No", "Yes"))
			
			return calc
		lineageTag: 2325cc3e-e6d3-4940-afff-d7e0183630ee
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MonthIndex = ```
			RANKX('App Usage',YEAR('App Usage'[Date])*100+MONTH('App Usage'[Date]),,ASC,Dense)
			
			```
		formatString: 0
		lineageTag: 34ae5604-d07e-4496-af5b-5894fd096d8d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

