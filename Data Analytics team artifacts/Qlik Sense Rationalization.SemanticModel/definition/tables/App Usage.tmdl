				    #"Filtered Rows" = Table.SelectRows(#"Changed Type", each ([#"User-facing App Workspace"] <> "-" and [#"User-facing App Workspace"] <> "Unpublished") and ([User Id] <> "-")),
				    #"Added Custom" = Table.AddColumn(#"Filtered Rows", "Duration", each [Session Finish] - [Session Start], type duration),
