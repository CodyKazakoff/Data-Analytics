				    #"Inserted Month Name" = Table.AddColumn(#"Renamed Columns", "Month", each Date.MonthName([Date]) & " " & Number.ToText(Date.Year([Date])), type text),
				    #"Filtered Rows1" = Table.SelectRows(#"Inserted Month Name", each [Date] > #date(2023, 9, 30))
				in
