	column Sales
		dataType: int64
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 764ca9ec-93d4-452a-9005-55f01498c8fb
		summarizeBy: sum
		sourceColumn: Sales

		annotation SummarizationSetBy = Automatic

	column Year = YEAR(Competitor_Sales_New[Reporting_Date])
		formatString: 0
		lineageTag: e97c6947-ebeb-40dd-ad45-713adc8cfb93
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Quarter = QUARTER(Competitor_Sales_New[Reporting_Date])
		formatString: 0
		lineageTag: 33429b36-6cf3-4edc-8a74-872b03018dc0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Growth_Change = ```
			
			VAR CurrentSales = Competitor_Sales_New[Sales]
			VAR PriorSales = 
			    LOOKUPVALUE(
			        Competitor_Sales_New[Sales],
			        Competitor_Sales_New[Company], Competitor_Sales_New[Company],
			        Competitor_Sales_New[Year], IF(Competitor_Sales_New[Quarter] = 1, Competitor_Sales_New[Year] - 1, Competitor_Sales_New[Year]),
			        Competitor_Sales_New[Quarter], IF(Competitor_Sales_New[Quarter] = 1, 4, Competitor_Sales_New[Quarter] - 1)
			    )
			RETURN
			    DIVIDE(
			        (CurrentSales - PriorSales),
			        PriorSales,
			        BLANK()
			    )
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 70468454-5797-4ad0-b56d-8f4c2bd5eaa2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Year_Quarter = FORMAT('Competitor_Sales_New'[Year], "0000") & " Q" & FORMAT('Competitor_Sales_New'[Quarter], "0")
		lineageTag: 85d67fd2-8c70-4219-8951-9430ed635dee
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

