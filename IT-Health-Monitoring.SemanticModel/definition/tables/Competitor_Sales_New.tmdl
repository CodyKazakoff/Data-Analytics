		formatString: m/d/yyyy
		lineageTag: 0d079312-178a-47d4-bda0-36b78334bb1d
		summarizeBy: none
		sourceColumn: Reporting_Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

