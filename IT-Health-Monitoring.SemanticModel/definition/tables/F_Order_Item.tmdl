				    // Add a step to convert ITM_CREATION_DATE to a date
				    #"Converted ITM_CREATION_DATE to Date" = Table.TransformColumns(dbo_F_Order_Item, {{"ITM_CREATION_DATE", each Date.From(_), type date}}),
				    #"Filtered Rows" = Table.SelectRows(#"Converted ITM_CREATION_DATE to Date", each (
				            [ORDER_TYPE_CD] = "O") and 
				            ([ITM_ITEM_STATUS_CD] <> "CL") and 
				            ([PROCESS_STATUS_DESC] <> "CLOSED") and 
				            ([ITM_UNIT_COST] <> 0) and 
